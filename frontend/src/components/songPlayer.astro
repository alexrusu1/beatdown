---
interface Props {
  gameCode?: string;
}
const { gameCode = "" } = Astro.props;
---

<div id="container" data-game-code={gameCode}>
    <button id="newBtn">🎲 New Song</button>
    <button id="playBtn"> ▶</button>
    <audio id="player"></audio>
</div>

<script>

  import { initializeApp } from "firebase/app";
  import { getDatabase, ref, set, onValue, push, update } from "firebase/database"; // Import Realtime Database specific functions

  const firebaseConfig = {
  apiKey: "YOUR_API_KEY", // Replace with your actual API Key
  authDomain: "beatdown-397a5.firebaseapp.com",
  databaseURL: "https://beatdown-397a5-default-rtdb.firebaseio.com", // Your database URL
  projectId: "beatdown-397a5",
  storageBucket: "beatdown-397a5.appspot.com",
  messagingSenderId: "YOUR_MESSAGING_SENDER_ID", // Replace with your actual ID
  appId: "YOUR_APP_ID", // Replace with your actual App ID
  };

  const app = initializeApp(firebaseConfig);
  const database = getDatabase(app);

  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("container");
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement | null;
    const newBtn = document.getElementById("newBtn") as HTMLButtonElement | null;
    const player = document.getElementById("player") as HTMLAudioElement | null;

    const gameCode = container?.getAttribute("data-game-code") ?? "";

    const playedTrackIds = new Set<number>();
    let availableSongs: any[] = [];
    let currentOffset = 0;
    const PAGE_LIMIT = 200;
    const SEARCH_TERM = "pop";

    async function loadSongs(): Promise<void> {
      const url = `https://itunes.apple.com/search?term=${encodeURIComponent(
        SEARCH_TERM
      )}&media=music&entity=song&limit=${PAGE_LIMIT}&offset=${currentOffset}`;

      const response = await fetch(url);
      const data = await response.json();

      if (!data.results || data.results.length === 0) {
        // We've paged past the end of the results
        throw new Error("No more songs found 😢");
      }

      // Songs with previews we haven't played yet across all pages so far
      const fresh = data.results.filter(
        (song: any) => song.previewUrl && !playedTrackIds.has(song.trackId)
      );

      // Move offset forward for the *next* time we need a new batch
      currentOffset += PAGE_LIMIT;

      if (fresh.length === 0) {
        // Everything in this page was already played; try the next page
        return loadSongs();
      }

      availableSongs = fresh;
    }

    async function getNextSong() {
      if (availableSongs.length === 0) {
        await loadSongs();
      }

      const index = Math.floor(Math.random() * availableSongs.length);
      const [song] = availableSongs.splice(index, 1);
      playedTrackIds.add(song.trackId);
      return song;
    }

    if (!playBtn || !newBtn || !player) return;

    if (gameCode) {
      const currentSongRef = ref(database, `games/${gameCode}/currentSong`);

      onValue(currentSongRef, (snapshot: any) => {
        const data = snapshot.val();
        if (!data?.previewUrl) return;
        if (player.src !== data.previewUrl) {
          player.src = data.previewUrl;
        }
        if (data.isPlaying !== false) {
          player.play().catch(() => {});
          playBtn.textContent = "⏸";
        } else {
          player.pause();
          playBtn.textContent = "▶";
        }
      });

      playBtn.onclick = () => {
        const nextPlaying = player.paused;
        update(currentSongRef, { isPlaying: nextPlaying });
      };

      newBtn.onclick = async () => {
        newBtn.disabled = true;
        playBtn.textContent = "▶";
        try {
          const song = await getNextSong();
          await set(currentSongRef, {
            previewUrl: song.previewUrl,
            trackName: song.trackName,
            artistName: song.artistName,
            startedAt: Date.now(),
            isPlaying: true,
          });
        } catch (error) {
          console.error("Error loading song:", error);
          alert(error instanceof Error ? error.message : "Error loading song 😢");
        }
        newBtn.disabled = false;
      };

      player.onended = () => {
        update(currentSongRef, { isPlaying: false });
        playBtn.textContent = "▶";
      };
      return;
    }

    playBtn.onclick = () => {
      if (player.paused) {
        player.play();
        playBtn.textContent = "⏸";
      } else {
        player.pause();
        playBtn.textContent = "▶";
      }
    };

    newBtn.onclick = async () => {
      playBtn.textContent = "▶";
      newBtn.disabled = true;
      try {
        const song = await getNextSong();
        player.src = song.previewUrl;
        await player.play();
        playBtn.textContent = "⏸";
      } catch (error) {
        console.error("Error loading song:", error);
        alert(error instanceof Error ? error.message : "Error loading song 😢");
      }
      newBtn.disabled = false;
    };

    player.onended = () => {
      playBtn.textContent = "▶";
    };
  });

</script>

<style>
  #container {
    margin: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
  }

  #playBtn {
    position: relative;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #00eaff;
    background: #02000a;
    text-shadow:
      0 0 8px rgba(0, 234, 255, 0.9),
      0 0 16px rgba(255, 0, 255, 0.7);
    box-shadow:
      0 0 20px rgba(0, 234, 255, 0.9),
      0 0 45px rgba(255, 0, 255, 0.8);
    outline: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

    #playBtn:hover {
    text-shadow:
      0 0 12px rgba(0, 234, 255, 0.9),
      0 0 24px rgba(255, 0, 255, 0.7);
    box-shadow:
      0 0 60px rgba(0, 234, 255, 0.9),
      0 0 120px rgba(255, 0, 255, 0.8);
  }

  #playBtn:active {
    transform: scale(0.95);
  }

    #newBtn {
    font-family: "Tilt Neon", sans-serif;
    margin-bottom: 20px;
    position: relative;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #00eaff;
    background: #02000a;
    text-shadow:
      0 0 8px rgba(0, 234, 255, 0.9),
      0 0 16px rgba(255, 0, 255, 0.7);
    box-shadow:
      0 0 20px rgba(0, 234, 255, 0.9),
      0 0 45px rgba(255, 0, 255, 0.8);
    outline: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

    #newBtn:hover {
    text-shadow:
      0 0 12px rgba(0, 234, 255, 0.9),
      0 0 24px rgba(255, 0, 255, 0.7);
    box-shadow:
      0 0 60px rgba(0, 234, 255, 0.9),
      0 0 120px rgba(255, 0, 255, 0.8);
  }
  #newBtn:active {
    transform: scale(0.95);
  }
</style>
