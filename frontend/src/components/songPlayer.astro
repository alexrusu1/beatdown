---

<div id="container">
  <button id="playBtn">▶ Play</button>
  <button id="newBtn">🎲 New Song</button>
  <audio id="player"></audio>
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement | null;
    const newBtn = document.getElementById("newBtn") as HTMLButtonElement | null;
    const player = document.getElementById("player") as HTMLAudioElement | null;

    if (!playBtn || !newBtn || !player) return;

    playBtn.onclick = () => {
      if (player.paused) {
        player.play();
        playBtn.textContent = "⏸ Pause";
      } else {
        player.pause();
        playBtn.textContent = "▶ Play";
      }
    };

    newBtn.onclick = async () => {
      playBtn.textContent = "▶ Play";
      playBtn.disabled = true;

      try {
        const searchTerm = "pop";
        const limit = 200;
        const url = `https://itunes.apple.com/search?term=${encodeURIComponent(searchTerm)}&media=music&entity=song&limit=${limit}`;

        const response = await fetch(url);
        const data = await response.json();

        if (data.resultCount > 0) {
          const randomIndex = Math.floor(Math.random() * data.results.length);
          const randomSong = data.results[randomIndex];

          console.log("Selected song:", {
            name: randomSong.trackName,
            artist: randomSong.artistName,
            album: randomSong.collectionName,
            previewUrl: randomSong.previewUrl
          });

          if (!randomSong.previewUrl) {
            alert("No preview available 😢");
            playBtn.disabled = false;
            return;
          }

          player.src = randomSong.previewUrl;
          await player.play();

          playBtn.textContent = "⏸ Pause";
          playBtn.disabled = false;
        } else {
          alert("No results found 😢");
          playBtn.disabled = false;
        }
      } catch (error) {
        console.error("Error fetching data:", error);
        alert("Error loading song 😢");
        playBtn.disabled = false;
      }
    };

    player.onended = () => {
      playBtn.textContent = "▶ Play";
    };
  });

</script>

<style>
  #container {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    height: 100vh;
  }
</style>
