<div id="container">
  <button id="playBtn">▶</button>
  <button id="newBtn">🎲 New Song</button>
  <audio id="player"></audio>
</div>

<script>

document.addEventListener("DOMContentLoaded", () => {
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement | null;
    const newBtn = document.getElementById("newBtn") as HTMLButtonElement | null;
    const player = document.getElementById("player") as HTMLAudioElement | null;

    // Keep track of what we've already played in this session
    const playedTrackIds = new Set<number>();
    let availableSongs: any[] = [];

    async function loadSongs() {
      const searchTerm = "pop";
      const limit = 200;
      const url = `https://itunes.apple.com/search?term=${encodeURIComponent(
        searchTerm
      )}&media=music&entity=song&limit=${limit}`;

      const response = await fetch(url);
      const data = await response.json();

      if (!data.results || data.results.length === 0) {
        throw new Error("No results found 😢");
      }

      // Only keep songs with previews that we haven't played yet
      availableSongs = data.results.filter(
        (song: any) => song.previewUrl && !playedTrackIds.has(song.trackId)
      );

      if (availableSongs.length === 0) {
        throw new Error("No new songs with previews available 😢");
      }
    }

    async function getNextSong() {
      if (availableSongs.length === 0) {
        await loadSongs();
      }

      const index = Math.floor(Math.random() * availableSongs.length);
      const [song] = availableSongs.splice(index, 1);
      playedTrackIds.add(song.trackId);
      return song;
    }

    if (!playBtn || !newBtn || !player) return;

    playBtn.onclick = () => {
      if (player.paused) {
        player.play();
        playBtn.textContent = "⏸";
      } else {
        player.pause();
        playBtn.textContent = "▶";
      }
    };

    newBtn.onclick = async () => {
      playBtn.textContent = "▶";
      playBtn.disabled = true;

      try {
        const song = await getNextSong();

        console.log("Selected song:", {
          name: song.trackName,
          artist: song.artistName,
          album: song.collectionName,
          previewUrl: song.previewUrl
        });

        player.src = song.previewUrl;
        await player.play();

        playBtn.textContent = "⏸";
        playBtn.disabled = false;
      } catch (error) {
        console.error("Error loading song:", error);
        alert(
          error instanceof Error ? error.message : "Error loading song 😢"
        );
        playBtn.disabled = false;
      }
    };

    player.onended = () => {
      playBtn.textContent = "▶";
    };
  });

</script>

<style>
  #container {
    margin: 1.5rem;
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
    height: 10vh;
  }

  #playBtn {
    position: relative;
    width: 140px;
    height: 140px;
    border-radius: 50%;
