---
---

<div id="game-container">
  <h1 id="game-code"></h1>
  <!-- Game Status Display -->
  <div id="game-status"></div>
  <div id="turn-indicator"></div>

  <!-- ADD PLAYER NAME INPUT -->
  <div id="lobby-controls">
    <div id="category-selection" style="margin-bottom: 20px;">
      <h3>Select Song Categories:</h3>
      <div class="checkbox-group">
        <label class="neon-checkbox"><input type="checkbox" id="category-pop" checked> <span class="checkbox-label">Pop</span></label>
        <label class="neon-checkbox"><input type="checkbox" id="category-hiphop"> <span class="checkbox-label">Hip-Hop/Rap</span></label>
        <label class="neon-checkbox"><input type="checkbox" id="category-rnb"> <span class="checkbox-label">R&B/Soul</span></label>
        <label class="neon-checkbox"><input type="checkbox" id="category-dance"> <span class="checkbox-label">Dance</span></label>
        <label class="neon-checkbox"><input type="checkbox" id="category-alternative"> <span class="checkbox-label">Alternative</span></label>
      </div>
    </div>

    <div id="year-selection" style="margin-bottom: 20px;">
      <h3>Select Song Year Range:</h3>
      <select id="year-range-select" class="neon-select">
        <option value="all">All Years</option>
        <option value="2020s">2020s+</option>
        <option value="2010s">2010s</option>
        <option value="2000s">2000s</option>
        <option value="1990s">1990s</option>
        <option value="1980s">1980s</option>
        <option value="1970s">1970s</option>
        <option value="1960s and before">1960s & Before</option>
      </select>
    </div>
    <button id="start-game">Start Game</button>
  </div>
  
  <!-- Player List -->
  <div id="player-list"></div>
  
  <!-- Music Player Controls -->
  <div id="music-controls">
  <button id="playBtn">▶</button>
  <button id="skip-btn" style="display:none">⏭ Skip</button>
  <audio id="player"></audio>

  <div id="song-progress">
    <div id="song-progress-bar"></div>
  </div>
</div>

  <!-- Guess Form -->
  <div id="guess-form" style="display: none;">
    <input id="song-input" placeholder="Song name" />
    <input id="artist-input" placeholder="Artist" />
    <input id="year-input" type="number" placeholder="Year" />
    <input id="album-input" placeholder="Album" />
    <button id="submit-guess">Submit Guess</button>
  </div>
  <div id="guess-timer" style="display: none; font-size: 2em; margin-top: 10px;"></div>
  
  <!-- Results Display -->
  <div id="results"></div>
  
  <!-- Phase Control Buttons -->
  <div id="phase-controls">
    <button id="reveal-btn" style="display: none;">Reveal Answers</button>
    <button id="resolve-btn" style="display: none;">Continue to Next Round</button>
    <button id="play-again-btn" style="display: none;">Play Again</button>
  </div>
</div>

<script>
  import { gameReducer, type Game, type GameAction } from "../game.logic/engine";
  import { initEngineEffects, handleEngineEffects } from "../game.logic/engine.effects";
  import { onAuthStateChanged } from "firebase/auth"; // Import authentication functions
  import type { User } from "firebase/auth"
  import { ref, set, onValue, push, update } from "firebase/database"; // Import Realtime Database specific functions
  import { realtimeDb, analytics, auth } from "../libraries/firebase";
  import songsData from "../data/songs.json";

  let currentUser: User | null = null; // Declare currentUser globally
  let myPlayerId: string | null = null; // To store the UID of the current user's player



  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("game-container");
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement;
    const skipBtn = document.getElementById("skip-btn") as HTMLButtonElement;
    const player = document.getElementById("player") as HTMLAudioElement;
    const progressBar = document.getElementById("song-progress-bar") as HTMLDivElement;
    const guessForm = document.getElementById("guess-form") as HTMLDivElement;
    const guessTimerEl = document.getElementById("guess-timer") as HTMLDivElement;
    const yearRangeSelect = document.getElementById("year-range-select") as HTMLSelectElement;
    const submitGuessBtn = document.getElementById("submit-guess") as HTMLButtonElement;
    const startGameBtn = document.getElementById("start-game") as HTMLButtonElement;
    
    // Extract the game code directly from the URL on the client-side
    const urlParams = new URLSearchParams(window.location.search);
    const gameCode = urlParams.get("code") ?? "";
    if (!gameCode) {
      console.error("No game code found");
      return;
    }
    document.getElementById("game-code")!.textContent = gameCode;

    player.addEventListener("timeupdate", () => {
      if (!progressBar || !player.duration) return;

      const percent = (player.currentTime / player.duration) * 100;
      progressBar.style.width = percent + "%";
    });

    // Song fetching logic (from songs.json)
    let allSongs: any[] = [];
    let availableSongs: any[] = [];
    let selectedCategories: string[] = ['pop']; // Default to pop only
    let selectedYearRange: string = 'all'; // Default to all years

    // Helper to filter songs by year range
    function filterSongsByYear(songs: any[], yearRange: string): any[] {
      if (!yearRange || yearRange === "all") return songs;

      const currentYear = new Date().getFullYear();
      let minYear = -Infinity;
      let maxYear = Infinity;

      if (yearRange === "2020s") {
        minYear = 2020; maxYear = currentYear;
      } else if (yearRange === "2010s") {
        minYear = 2010; maxYear = 2019;
      } else if (yearRange === "2000s") {
        minYear = 2000; maxYear = 2009;
      } else if (yearRange === "1990s") {
        minYear = 1990; maxYear = 1999;
      } else if (yearRange === "1980s") {
        minYear = 1980; maxYear = 1989;
      } else if (yearRange === "1970s") {
        minYear = 1970; maxYear = 1979;
      } else if (yearRange === "1960s and before") {
        minYear = 0; maxYear = 1969; // Effectively any year before 1970
      }
      return songs.filter(song => song.year >= minYear && song.year <= maxYear);
    }

    async function loadSongs(): Promise<void> {
      console.log("loadSongs called with selectedCategories:", selectedCategories);
      if (allSongs.length === 0) {
        // Ensure we have categories selected
        if (selectedCategories.length === 0) {
          console.warn("No categories selected, defaulting to pop");
          selectedCategories = ['pop'];
        }
        
        // Load songs from API using POST with JSON body containing categories
        // const endpoint = '/api/songs';
        // console.log("POSTing to", endpoint, "with categories", selectedCategories);
        // const response = await fetch(endpoint, {
        //   method: 'POST',
        //   headers: { 'Content-Type': 'application/json' },
        //   body: JSON.stringify({ categories: selectedCategories })
        // });np
        
        // if (!response.ok) {
        //   throw new Error(`Failed to fetch songs: ${response.status}`);
        // }
        
        // allSongs = await response.json();

        // Filter static JSON data directly on the client side
        const categoryMap: Record<string, string> = {
          'pop': 'Pop',
          'hiphop': 'Hip-Hop/Rap',
          'rnb': 'R&B/Soul',
          'dance': 'Dance',
          'alternative': 'Alternative'
        };
        const mappedCategories = selectedCategories.map(c => categoryMap[c] || c);
        
        allSongs = songsData.filter((song: any) => 
          song.categories && song.categories.some((c: string) => mappedCategories.includes(c)) &&
          // Apply year filter here
          filterSongsByYear([song], selectedYearRange).length > 0

        );
        console.log("Loaded songs:", allSongs.length, "first categories:", allSongs[0]?.categories);
      }
      
      availableSongs = [...allSongs]; // All loaded songs are already filtered
      
      if (availableSongs.length === 0) {
        throw new Error("No songs found for selected categories 😢");
      }
      console.log("Available songs:", availableSongs.length);
    }

    async function getNextSong() {
      if (availableSongs.length === 0) {
        await loadSongs();
      }

      const index = Math.floor(Math.random() * availableSongs.length);
      const [song] = availableSongs.splice(index, 1);
      console.log("Raw song from JSON:", song);
      
      // Convert songs.json format to Game format
      return {
        displayName: song.displayName,
        answerNames: song.answerNames,
        album: song.album,
        albumAnswers: song.albumAnswers,
        displayArtists: song.displayArtists,
        artists: song.artists,
        year: song.year,
        previewUrl: song.previewUrl,  // note: json has lowercase 'l', interface has uppercase 'L'
        isPlaying: false
      };

    }

    // Initialize game state
    let game: Game = {
      phase: "LOBBY",
      players: [],
      turnIndex: 0,
      currentSong: null,
      originalGuesses: {},
      circleGuesses: {},
      answerRevealed: false,
      guessStartTime: null,
      guessTimeLimit: 30, // 30 seconds for guessing
      categories: ['pop'], // Initialize with default categories
      selectedYearRange: 'all' // Initialize with default year range
    };

    // helper to figure out whose turn it is to guess
    function getActiveGuesserId(): string | null {
      if (game.phase === "SONG_PLAYING") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "ORIGINAL_GUESS_TURN") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        return game.players[game.circleGuessIndex]?.uid?.toString() ?? null;
      }

      return null;
    }

    let guessCountdownInterval: NodeJS.Timeout | null = null;
  let songPlayedThisRound = false;

    function dispatch(action: GameAction) {
      const prevGame = game;
      game = gameReducer(game, action);

      // Handle side effects
      handleEngineEffects(prevGame, game, player);

      // Clear previous countdown if phase changes
      if (game.phase !== prevGame.phase && guessCountdownInterval) {
        clearInterval(guessCountdownInterval);
        guessCountdownInterval = null;
        guessTimerEl.style.display = 'none';
      }

      // Update UI
      renderGame();

      // Sync to Firebase if multiplayer
      if (gameCode) {
        const gameRef = ref(realtimeDb, `games/${gameCode}`);
        // Firestore/RealtimeDB rejects undefined values.
        let gameToWrite: any = JSON.parse(JSON.stringify(game));
        if (gameToWrite.circleGuessIndex === undefined) {
          delete gameToWrite.circleGuessIndex;
        }
        try {
            // Ensure players are stored in Firebase as an object keyed by uid
            if (Array.isArray(gameToWrite.players)) {
              const playersObj: any = {};
              for (const p of gameToWrite.players) {
                // Firebase doesn't like undefined values, so ensure they are null or removed
                if (p.isHost === undefined) delete p.isHost;
                if (p.uid === undefined) delete p.uid; // Should not happen but for safety
                if (p && p.uid !== undefined) playersObj[p.uid] = p;
              }
              gameToWrite.players = playersObj;
            }
            set(gameRef, gameToWrite);
        } catch (err) {
          console.error("Failed to sync game to Firebase", err, gameToWrite);
        }
      }
    }

    // helper to load song when phase is SONG_PLAYING and none yet
    async function maybeLoadSong() {
      console.log("maybeLoadSong invoked", { phase: game.phase, currentSong: !!game.currentSong, myPlayerId, players: game.players.length });
      if (!myPlayerId) return;
      if (game.phase === "SONG_PLAYING" && !game.currentSong) {
        const origGuesserId = game.players[game.turnIndex]?.uid;
        const host = game.players.find(p => p.isHost)?.uid;
        
        // Only the original guesser or host should load songs to prevent conflicts
        const shouldLoad = myPlayerId === origGuesserId || myPlayerId === host;
        console.log("maybeLoadSong decision", { origGuesserId, host, shouldLoad });
        
        if (shouldLoad) {
          console.log("maybeLoadSong deciding to fetch (orig or host)", { origGuesserId, host });
          try {
            const song = await getNextSong();
            console.log("Loaded song:", song.displayName);
            dispatch({ type: "PLAY_SONG", song: { ...song, isPlaying: false } });
          } catch (err) {
            console.error("Failed to load initial song", err);
          }
        } else {
          console.log("maybeLoadSong - not authorized to fetch", { origGuesserId, host });
        }
      }
    }

    // authentication observer moved inside DOMContentLoaded so dispatch is available
    onAuthStateChanged(auth, (user) => {
      if (user) {
        currentUser = user;
        myPlayerId = user.uid; // Store the UID
        console.log("Game component: Authenticated user UID:", myPlayerId);
        maybeLoadSong(); // try load if phase already started
      } else {
        currentUser = null;
        myPlayerId = null;
        console.warn("Game component: No user authenticated. User might have signed out or session expired.");
      }
    });
    // Category selection logic
    function updateSelectedCategories() {
      console.log("updateSelectedCategories called");
      const oldCategories = [...selectedCategories];
      selectedCategories = [];
      const checkboxes = [
        { id: 'category-pop', value: 'pop' },
        { id: 'category-hiphop', value: 'hiphop' },
        { id: 'category-rnb', value: 'rnb' },
        { id: 'category-dance', value: 'dance' },
        { id: 'category-alternative', value: 'alternative' }
      ];
      
      checkboxes.forEach(({ id, value }) => {
        const checkbox = document.getElementById(id) as HTMLInputElement;
        if (checkbox?.checked) {
          selectedCategories.push(value);
        }
      });
      
      console.log("Selected categories:", selectedCategories);
      
      // Ensure at least one category is selected
      if (selectedCategories.length === 0) {
        selectedCategories = ['pop'];
        const popCheckbox = document.getElementById('category-pop') as HTMLInputElement;
        if (popCheckbox) popCheckbox.checked = true;
      }
      
      // Dispatch SET_CATEGORIES action if categories changed (only for host)
      if (JSON.stringify(oldCategories.sort()) !== JSON.stringify(selectedCategories.sort())) {
        console.log("Categories changed, dispatching SET_CATEGORIES");
        const host = game.players.find(p => p.isHost);
        if (host?.uid === myPlayerId) {
          dispatch({ type: "SET_CATEGORIES", categories: selectedCategories });
        }
        // Clear song cache if categories changed
        allSongs = [];
        availableSongs = [];
      }
    }

    // Initialize category checkboxes
    const categoryCheckboxes = ['category-pop', 'category-hiphop', 'category-rnb', 'category-dance', 'category-alternative'];
    categoryCheckboxes.forEach(id => {
      const checkbox = document.getElementById(id) as HTMLInputElement;
      if (checkbox) {
        checkbox.addEventListener('change', updateSelectedCategories);
      }
    });
    
    // Initial category update
    updateSelectedCategories();

    // Initialize effects
    initEngineEffects(player, () => game, dispatch);

    // Firebase sync for multiplayer
    if (gameCode) {
      const gameRef = ref(realtimeDb, `games/${gameCode}`);
      
      onValue(gameRef, (snapshot) => {
        const data = snapshot.val();
        if (data) {
          const prevGame = game;

          // sanitize players list from firebase object
          const playersArray = data.players
            ? Object.entries(data.players as Record<string, any>)
                .filter(([, p]) => p != null)
                .map(([uid, playerObj]) => ({
                  uid: uid.toString(),
                  ...playerObj
                }))
            : [];

          // clamp index values to avoid bad accesses
          if (game.turnIndex >= playersArray.length || game.turnIndex < 0) {
            console.warn("Firebase sync: turnIndex out of bounds, resetting to 0", game.turnIndex, playersArray.length);
            game.turnIndex = 0;
          }
          if (
            game.circleGuessIndex !== undefined &&
            (game.circleGuessIndex >= playersArray.length || game.circleGuessIndex < 0)
          ) {
            console.warn(
              "Firebase sync: circleGuessIndex out of bounds, resetting to 0",
              game.circleGuessIndex,
              playersArray.length
            );
            game.circleGuessIndex = 0;
          }

          // build new game state with defaults for missing fields
          game = {
            phase: data.phase ?? "LOBBY",
            players: playersArray,
            turnIndex: data.turnIndex ?? 0,
            circleGuessIndex: data.circleGuessIndex,
            currentSong: data.currentSong ?? null,
            originalGuesses: data.originalGuesses || {},
            circleGuesses: data.circleGuesses || {},
            answerRevealed: data.answerRevealed ?? false,
            guessStartTime: data.guessStartTime ?? null,
            guessTimeLimit: data.guessTimeLimit ?? 30, // Default to 30 seconds
            winner: data.winner ?? undefined,
            selectedYearRange: data.selectedYearRange ?? 'all', // Default to 'all'
            categories: data.categories ?? ['pop']
          };

          // Update selectedCategories from loaded game state
          if (game.categories && game.categories.length > 0) {
            const oldCategories = [...selectedCategories];
            selectedCategories = [...game.categories];
            console.log("Updated selectedCategories from Firebase:", selectedCategories);
            
            // Clear song cache when categories change for all players
            if (JSON.stringify(oldCategories.sort()) !== JSON.stringify(selectedCategories.sort())) {
              console.log("Categories changed from Firebase, clearing song cache");
              allSongs = [];
              availableSongs = [];
            }

            // Update local year range from game state and clear song cache if needed
            if (game.selectedYearRange && game.selectedYearRange !== selectedYearRange) {
              const oldYearRange = selectedYearRange;
              selectedYearRange = game.selectedYearRange;
              console.log("Updated selectedYearRange from Firebase:", selectedYearRange);
              if (oldYearRange !== selectedYearRange) {
                console.log("Year range changed from Firebase, clearing song cache");
                allSongs = [];
                availableSongs = [];
              }
            }

            // Update year range select UI
            if (yearRangeSelect && yearRangeSelect.value !== game.selectedYearRange) {
              yearRangeSelect.value = game.selectedYearRange;
            }

          }

          console.log("Local game.players after Firebase update and transformation:", game.players);
          if (playersArray.length !== prevGame.players.length) {
            console.log("Players count changed from", prevGame.players.length, "to", playersArray.length);
          }

          handleEngineEffects(prevGame, game, player);
          // if we're in SONG_PLAYING and still have no song, check again
          if (game.phase === "SONG_PLAYING" && !game.currentSong) {
            maybeLoadSong();
          }
          renderGame();
        } else {
          console.warn("Game data is null or undefined from Firebase.");
        }
      });
    }

    // UI Event Handlers

// START GAME HANDLER
    startGameBtn.addEventListener("click", () => {
      const host = game.players.find(p => p.isHost);
      if (host?.uid !== myPlayerId) return; // only host may start
      if (game.players.length < 2) {
        alert("Need at least 2 players to start!");
        return;
      }
      
      // Update selected categories before starting
      updateSelectedCategories();
      console.log("categories: ", selectedCategories);
      
      // Set categories in game state
      dispatch({ type: "SET_CATEGORIES", categories: selectedCategories });
      dispatch({ type: "SET_YEAR_RANGE", yearRange: selectedYearRange });
      dispatch({ type: "START_GAME" });
    });

    skipBtn.onclick = () => {
      // only the original guesser may skip
      const origId = game.players[game.turnIndex]?.uid;
      if (gameCode && origId !== myPlayerId) return;
      if (game.phase === "SONG_PLAYING") {
        dispatch({ type: "END_SONG" });
      }
    };

    playBtn.onclick = () => {
      // only the active guesser may toggle play/pause
      const activeId = getActiveGuesserId();
      if (gameCode && myPlayerId !== activeId) {
        console.log("🔒 play/pause disabled for non-active player");
        return;
      }
      // toggle play state via reducer so it syncs to Firebase
      const currentlyPlaying = game.currentSong?.isPlaying ?? false;
      dispatch({ type: "SET_PLAYING", playing: !currentlyPlaying });
    };
    submitGuessBtn.onclick = () => {
      const songInput = document.getElementById("song-input") as HTMLInputElement;
      const artistInput = document.getElementById("artist-input") as HTMLInputElement;
      const yearInput = document.getElementById("year-input") as HTMLInputElement;
      const albumInput = document.getElementById("album-input") as HTMLInputElement;

      const song = songInput.value;
      const artist = artistInput.value;
      const year = parseInt(yearInput.value);
      const album = albumInput.value;

      const activeId = getActiveGuesserId();
      if (game.phase === "ORIGINAL_GUESS_TURN") {
        if (activeId !== myPlayerId) return; // ignore others
        dispatch({
          type: "ORIGINAL_GUESS_SUBMIT",
          guesses: { song, artist, year, album }
        });
      } else if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        if (activeId !== myPlayerId) return;
        const currentCirclePlayer = game.players[game.circleGuessIndex];
        dispatch({
        type: "CIRCLE_GUESS_SUBMIT",
        playerId: String(currentCirclePlayer.uid),  // ← use String() instead of as number
        guesses: { song, artist, year, album }
      });
      }

      // Clear all input fields after submitting
      songInput.value = "";
      artistInput.value = "";
      yearInput.value = "";
      albumInput.value = "";
    };

    // PHASE PROGRESSION BUTTONS
    const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
    const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;
    const playAgainBtn = document.getElementById("play-again-btn") as HTMLButtonElement;

    revealBtn?.addEventListener("click", () => {
      dispatch({ type: "REVEAL_ANSWERS" });
    });

    resolveBtn?.addEventListener("click", () => {
      dispatch({ type: "RESOLVE_ROUND" });
      setTimeout(() => renderGame(), 10);
    });

    playAgainBtn?.addEventListener("click", () => {
      const host = game.players.find(p => p.isHost);
      if (host?.uid !== myPlayerId) return; // only the host can choose to play again
      dispatch({ type: "START_GAME" });
    });

    // Render game state to UI
    function renderGame() {
      
      console.log("Rendering game. Current players in renderGame():", game.players);

      const statusEl = document.getElementById("game-status");
      const turnIndicator = document.getElementById("turn-indicator");
      const playerListEl = document.getElementById("player-list");
      const resultsEl = document.getElementById("results");
      const lobbyControls = document.getElementById("lobby-controls");
      const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
      const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;
      const playAgainBtn = document.getElementById("play-again-btn") as HTMLButtonElement;
      const yearSelection = document.getElementById("year-selection");

      if (!statusEl || !playerListEl || !resultsEl) return;

      // ADD THIS: Reset song flag when entering SONG_PLAYING phase
      if (game.phase === "SONG_PLAYING" && songPlayedThisRound) {
        songPlayedThisRound = false;
      }

      // HIDE LOBBY CONTROLS WHEN GAME STARTS
      if (lobbyControls) {
        lobbyControls.style.display = game.phase === "LOBBY" ? "block" : "none";
      }
      // Hide year selection if not in lobby
      if (yearSelection) {
        yearSelection.style.display = game.phase === "LOBBY" ? "block" : "none";
      }
      
      // Update category checkboxes based on game state (only in lobby)
      if (game.phase === "LOBBY" && game.categories) {
        const categoryMap = {
          'pop': 'category-pop',
          'hiphop': 'category-hiphop', 
          'rnb': 'category-rnb',
          'dance': 'category-dance',
          'alternative': 'category-alternative'
        };
        
        const host = game.players.find(p => p.isHost);
        const isHost = host?.uid === myPlayerId;
        
        Object.entries(categoryMap).forEach(([category, checkboxId]) => {
          const checkbox = document.getElementById(checkboxId) as HTMLInputElement;
          if (checkbox) {
            checkbox.checked = game.categories!.includes(category);
            checkbox.disabled = !isHost; // Only host can change categories
          }
        });
        
        // Update selectedCategories to match game state
        selectedCategories = game.categories;

        // Update year range select UI
        if (yearRangeSelect) {
          if (yearRangeSelect.value !== game.selectedYearRange) {
            yearRangeSelect.value = game.selectedYearRange;
          }
          yearRangeSelect.disabled = !isHost;
        }
        console.log("Updated selectedCategories from game state:", selectedCategories);
      }
      // show / hide start button and disable for non-hosts
      const host = game.players.find(p => p.isHost);
      if (startGameBtn) {
        if (host?.uid !== myPlayerId) {
          startGameBtn.style.display = "none";
        } else {
          startGameBtn.style.display = "inline-block";
        }
        startGameBtn.disabled = game.players.length < 2;
      }

      // Update phase display (fallback to LOBBY if DB missing)
      const phaseDisplay = game.phase || "LOBBY";
      statusEl.textContent = `Phase: ${phaseDisplay}`;

    if (game.players.length > 0) {
      // make sure indices are valid to avoid undefined access
      if (game.turnIndex >= game.players.length || game.turnIndex < 0) {
        console.warn("renderGame: turnIndex out of bounds", game.turnIndex, game.players.length);
      }
      const currentPlayer = game.players[game.turnIndex] || { name: "(none)" };
      statusEl.textContent += ` | Original Guesser: ${currentPlayer.name}`;
      
      // Show circle guesser
      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        if (game.circleGuessIndex >= game.players.length || game.circleGuessIndex < 0) {
          console.warn("renderGame: circleGuessIndex out of bounds", game.circleGuessIndex, game.players.length);
        }
        const circlePlayer = game.players[game.circleGuessIndex] || { name: "(none)" };
        statusEl.textContent += ` | Circle Turn: ${circlePlayer.name}`;
      }
    }

      // Update player list, marking host
      playerListEl.innerHTML = game.players
      .map(p => {

        const activeId = getActiveGuesserId();
        const isActive = p.uid === activeId;

        return `
        <div class="player-card ${isActive ? "active-player" : ""}">

          <div class="player-row">

            <div class="avatar">
              ${p.name ? p.name[0].toUpperCase() : "?"}
            </div>

            <div class="player-info">
              <div class="player-name">
                ${p.name || "Unknown"} ${p.isHost ? "👑" : ""}
              </div>

              <div class="health-bar">
                <div class="health-fill" style="width:${p.health}%"></div>
              </div>

            </div>

          </div>

        </div>
        `;
      })
      .join("");

      // Show/hide guess form based on phase *and* active guesser
      const activeId = getActiveGuesserId();
      const activePlayer = game.players.find(p => p.uid === activeId);
      if (turnIndicator) {
        if (activePlayer) {
          turnIndicator.textContent = `🎤 ${activePlayer.name}'s Turn`;
        } else {
          turnIndicator.textContent = "";
        }
      }
      if (
        (game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN") &&
        activeId === myPlayerId
      ) {
        guessForm.style.display = "block";
      } else {
        guessForm.style.display = "none";
      }

      // Update and display guess timer
      if ((game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN") && game.guessStartTime !== null) {
        guessTimerEl.style.display = "block";
        if (guessCountdownInterval) {
          clearInterval(guessCountdownInterval);
        }
        guessCountdownInterval = setInterval(() => {
          const elapsed = Math.floor((Date.now() - game.guessStartTime!) / 1000);
          const remaining = Math.max(0, game.guessTimeLimit - elapsed);
          guessTimerEl.textContent = `Time left: ${remaining}s`;
          if (remaining <= 0) {
            clearInterval(guessCountdownInterval!);
            guessCountdownInterval = null;
            // The GUESS_TIMEOUT action is dispatched by engine.effects.ts
          }
        }, 1000);
      } else {
        if (guessCountdownInterval) clearInterval(guessCountdownInterval);
        guessTimerEl.style.display = 'none';
      }

      // Show results
      if (game.phase === "REVEAL_RESULTS" && game.currentSong) {
        resultsEl.innerHTML = `
          <h3>Answer:</h3>
          <p>Song: ${game.currentSong.displayName}</p>
          <p>Artist: ${game.currentSong.displayArtists}</p>
          <p>Year: ${game.currentSong.year}</p>
          <p>Album: ${game.currentSong.album}</p>
        `;
      } else {
        resultsEl.innerHTML = "";
      }

      // Show game over screen
      if (game.phase === "GAME_OVER") {
        const winner = game.players.find(p => p.uid === game.winner);
        resultsEl.innerHTML = `
          <h2>🎉 Game Over! 🎉</h2>
          <p>${winner ? `${winner.name} wins!` : "No winner"}</p>
        `;
      }

      // Control button visibility based on phase
      if (revealBtn) revealBtn.style.display = 
        game.phase === "WAITING_TO_REVEAL" ? "block" : "none";
      
      if (resolveBtn) resolveBtn.style.display = 
        game.phase === "REVEAL_RESULTS" ? "block" : "none";

      if (playAgainBtn) {
        playAgainBtn.style.display = (game.phase === "GAME_OVER" && host?.uid === myPlayerId) ? "block" : "none";
      }

      // Enable/disable music controls based on phase, host status and active guesser
      const me = game.players.find(p => p.uid === myPlayerId);
      const isHost = me?.isHost;
      // activeId already computed above when showing the guess form
      playBtn.disabled = gameCode ? myPlayerId !== activeId : false;

      // hide play button when not listening
      playBtn.style.display = game.phase === "SONG_PLAYING" ? "inline-block" : "none";

      // show skip button only when a song is loaded and only for the original
      // guesser (turn player) while listening
      const origGuesserId = game.players[game.turnIndex]?.uid;
      if (skipBtn) {
        skipBtn.style.display =
          game.phase === "SONG_PLAYING" &&
          game.currentSong &&
          origGuesserId === myPlayerId
            ? "inline-block"
            : "none";
      }

      // reflect play button based on state
      if (game.currentSong?.isPlaying) {
        playBtn.textContent = "⏸";
      } else {
        playBtn.textContent = "▶";
      }
    }  // ← Function closes HERE, not earlier

    // Initial render
    renderGame();
  });
</script>

