---
---

<div id="game-container">
  <h1 id="game-code"></h1>
  <!-- Game Status Display -->
  <div id="game-status"></div>
  <div id="turn-indicator"></div>  

  <div id="lobby-controls">
    <!-- Mode Selector -->
    <div class="game-mode-selector">
      <label for="mode-select">Game Mode:</label>
      <select id="mode-select">
        <option value="CLASSIC">Classic</option>
        <option value="RACE">Race</option>
      </select>
    </div>

    <div id="song-mixer-container" class="song-selection-container">
      <div class="mixer-header">
        <button id="select-all-btn">Select All</button>
        <h4>The DJ Equalizer</h4>
        <button id="clear-mixer-btn">Clear All</button>
      </div>
      <div id="mixer-board">
        <!-- Mixer channels will be rendered here by JavaScript -->
      </div>
    </div>
    
    <button id="start-game">Start Game</button>
  </div>
  
  <!-- Player List -->
  <div id="player-list"></div>
  
  <!-- Music Player Controls -->
  <div id="music-controls" style="display: none;">
    <audio id="player" preload="auto"></audio>
    <button id="playBtn">▶</button>
    <button id="skip-btn">Skip Song</button>
    <div id="song-progress"><div id="song-progress-bar"></div></div>
  </div>

  <!-- Guess Form -->
  <div id="guess-form" style="display: none;">
    <input id="song-input" placeholder="Song name" />
    <input id="artist-input" placeholder="Artist" />
    <input id="year-input" type="number" placeholder="Year" />
    <input id="album-input" placeholder="Album" />
    <button id="submit-guess">Pass</button>
  </div>
  <div id="guess-timer" style="display: none; font-size: 2em; margin-top: 10px;"></div>
  
  <!-- Results Display -->
  <div id="results"></div>
  
  <!-- Phase Control Buttons -->
  <div id="phase-controls">
    <button id="reveal-btn" style="display: none;">Reveal Answers</button>
    <button id="resolve-btn" style="display: none;">Continue to Next Round</button>
    <button id="play-again-btn" style="display: none;">Play Again</button>
  </div>

  <!-- Autoplay Blocked Overlay -->
  <div id="audio-unlock-overlay" style="display: none;">
    <h2>Tap anywhere to hear the song! 🎵</h2>
  </div>
</div>

<script>
  import { gameReducer, type Game, type GameAction, type SongSelection } from "../game.logic/engine";
  import { initEngineEffects, handleEngineEffects } from "../game.logic/engine.effects";
  import { filterSongs } from "../scripts/song-filtering"; // Corrected path
  import { onAuthStateChanged } from "firebase/auth"; // Import authentication functions
  import type { User } from "firebase/auth"
  import { ref, set, onValue, update } from "firebase/database"; // Added update for potential future use, though set is used here
  import { realtimeDb, auth } from "../libraries/firebase"; // Removed analytics as it's not used
  import allSongsData from "../data/songs.json";
  let currentUser: User | null = null; // Declare currentUser globally
  let myPlayerId: string | null = null; // To store the UID of the current user's player



  let dispatchInternal: (action: GameAction) => void; // Declare dispatchInternal at a higher scope
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("game-container");
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement; // Now exists in HTML
    const skipBtn = document.getElementById("skip-btn") as HTMLButtonElement; // Now exists in HTML
    const player = document.getElementById("player") as HTMLAudioElement;
    const guessTimerEl = document.getElementById("guess-timer") as HTMLDivElement;
    const progressBar = document.getElementById("song-progress-bar") as HTMLDivElement;
    const guessForm = document.getElementById("guess-form") as HTMLDivElement;
    const modeSelect = document.getElementById("mode-select") as HTMLSelectElement;
    const submitGuessBtn = document.getElementById("submit-guess") as HTMLButtonElement;
    const songInput = document.getElementById("song-input") as HTMLInputElement;
    const artistInput = document.getElementById("artist-input") as HTMLInputElement;
    const yearInput = document.getElementById("year-input") as HTMLInputElement;
    const albumInput = document.getElementById("album-input") as HTMLInputElement;

    const startGameBtn = document.getElementById("start-game") as HTMLButtonElement;
    const clearMixerBtn = document.getElementById("clear-mixer-btn") as HTMLButtonElement;
    const selectAllBtn = document.getElementById("select-all-btn") as HTMLButtonElement;
    
    const urlParams = new URLSearchParams(window.location.search);
    const gameCode = urlParams.get("code") ?? "";
    if (!gameCode) {
      console.error("No game code found");
      return;
    }
    document.getElementById("game-code")!.textContent = gameCode;

    // Handle mobile browser autoplay blocking
    window.addEventListener("audio-autoplay-failed", () => {
      const overlay = document.getElementById("audio-unlock-overlay");
      if (overlay) {
        overlay.style.display = "flex";
        overlay.onclick = () => {
          overlay.style.display = "none";
          player.play().catch(e => console.error("Overlay play failed", e));
        };
      }
    });

    player.addEventListener("timeupdate", () => {
      if (!progressBar) return;
      if (!player.duration || isNaN(player.duration) || !isFinite(player.duration)) {
        progressBar.style.width = "0%";
        return;
      }

      const percent = (player.currentTime / player.duration) * 100;
      progressBar.style.width = percent + "%";
    });

    // --- Song Selection State and Logic ---
    const availableYears = ["2020s", "2010s", "2000s", "1990s", "1980s", "1970s", "≤ 1960s"];
    const availableCategories = ["Rock", "Hip-Hop/Rap", "R&B/Soul", "Pop", "Dance", "Alternative"];
    let currentSongSelections: SongSelection[] = []; // Default to empty (all songs)

    // Initialize game state
    let game: Game = {
      phase: "LOBBY",
      mode: "CLASSIC",
      readyPlayers: [],
      skipVotes: [],
      players: [],
      turnIndex: 0,
      currentSong: null,
      originalGuesses: {},
      circleGuesses: {},
          preFireGuesses: {}, // Initialize preFireGuesses
      answerRevealed: false,
      guessStartTime: null,
      guessTimeLimit: 30, // 30 seconds for guessing
      songSelections: [], 
    };

    const updateSubmitButtonText = () => {
      if (game.mode === "RACE") {
        submitGuessBtn.textContent = "Submit Guess";
      } else {
        const hasInput = songInput.value || artistInput.value || yearInput.value || albumInput.value;
        submitGuessBtn.textContent = hasInput ? "Submit Guess" : "Pass";
      }
    };
    [songInput, artistInput, yearInput, albumInput].forEach(el => el.addEventListener('input', updateSubmitButtonText));

    const clearGuessInputs = () => {
      songInput.value = "";
      artistInput.value = "";
      yearInput.value = "";
      albumInput.value = "";
      updateSubmitButtonText();
    };

    [songInput, artistInput, yearInput, albumInput].forEach(el => el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        submitGuessBtn.click();
      }
    }));

    // helper to figure out whose turn it is to guess
    function getActiveGuesserId(): string | null {
      if (game.phase === "SONG_PLAYING") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "ORIGINAL_GUESS_TURN") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        return game.players[game.circleGuessIndex]?.uid?.toString() ?? null;
      }

      return null;
    }

    // Song fetching logic (from songs.json)
    let availableSongsForGame: any[] = [];
    async function loadSongsForGame(): Promise<void> {
      console.log("loadSongsForGame called with selections:", game.songSelections);
      availableSongsForGame = filterSongs(game.songSelections);
      console.log("Available songs for game:", availableSongsForGame.length);
    }


    let guessCountdownInterval: NodeJS.Timeout | null = null;
  let songPlayedThisRound = false;
  let isFirebaseLoaded = false;
  let isDraggingMixer = false;

  document.addEventListener("pointerup", () => {
    if (isDraggingMixer) {
      isDraggingMixer = false;
      dispatchInternal({ type: "SET_SONG_SELECTIONS", selections: currentSongSelections });
    }
  });

  document.addEventListener("pointercancel", () => {
    if (isDraggingMixer) {
      isDraggingMixer = false;
      dispatchInternal({ type: "SET_SONG_SELECTIONS", selections: currentSongSelections });
    }
  });

    // Centralized dispatch function (assigned here, but declared above)
    dispatchInternal = (action: GameAction) => {
      const prevGame = { ...game }; // Create a shallow copy for handleEngineEffects
      game = gameReducer(game, action);

      handleEngineEffects(prevGame, game, player);

      // Clear previous countdown if phase changes
      if (game.phase !== prevGame.phase && guessCountdownInterval) {
        clearInterval(guessCountdownInterval);
        guessCountdownInterval = null;
        guessTimerEl.style.display = 'none';
      }
      
      // Clear inputs at the start of a new round
      if (game.phase === "SONG_PLAYING" && prevGame.phase !== "SONG_PLAYING") {
        clearGuessInputs();
      }

      // Update UI
      renderGame();

      // Sync to Firebase if multiplayer (only if gameCode exists)
      if (gameCode && isFirebaseLoaded) {
        const gameRef = ref(realtimeDb, `games/${gameCode}`);
        // Firestore/RealtimeDB rejects undefined values.
        let gameToWrite: any = JSON.parse(JSON.stringify(game));
        if (gameToWrite.circleGuessIndex === undefined) {
          delete gameToWrite.circleGuessIndex;
        }
        // Ensure players are stored in Firebase as an object keyed by uid, and handle potential undefined values
        const playersObj: { [key: string]: any } = {}; // Explicitly type playersObj
        gameToWrite.players.forEach((p: any) => playersObj[p.uid] = { ...p, uid: p.uid.toString() }); // Ensure uid is string
        gameToWrite.players = playersObj; // Assign the object back
        set(gameRef, gameToWrite)
          .catch((err) => console.error("Failed to sync game to Firebase:", err));
      }
    };

    async function getNextSong() { // Moved outside dispatch for clarity
      if (availableSongsForGame.length === 0) {
        await loadSongsForGame();
      }
      if (availableSongsForGame.length === 0) {
        console.error("No songs available to pick from after loading.");
        return null;
      }

      const index = Math.floor(Math.random() * availableSongsForGame.length);
      const [song] = availableSongsForGame.splice(index, 1);
      console.log("Picked song:", song.displayName);
      return song;
    }

    async function maybeLoadNewSongIntoGame() { // Renamed from maybeLoadSong
      console.log("maybeLoadNewSongIntoGame invoked", { phase: game.phase, currentSong: !!game.currentSong, myPlayerId, players: game.players.length });
      const host = game.players.find(p => p.isHost);
      if (!myPlayerId || host?.uid !== myPlayerId) return; // Only host loads new songs

      if (game.phase === "SONG_PLAYING" && !game.currentSong) {
        try {
          const song = await getNextSong();
          if (song) {
            console.log("Loaded song:", song.displayName); // Log song details
            dispatchInternal({ type: "PLAY_SONG", song: { ...song, isPlaying: game.mode === "RACE" } });
          } else {
            console.warn("Could not get a new song.");
          }
        } catch (err) {
          console.error("Failed to load initial song", err);
        }
      }
    }

    // authentication observer
    onAuthStateChanged(auth, (user) => {
      if (user) {
        currentUser = user;
        myPlayerId = user.uid; // Store the UID
        console.log("Authenticated user UID:", myPlayerId); // No need to call maybeLoadSong here, onValue will handle initial state sync
        renderGame();
      } else {
        currentUser = null;
        myPlayerId = null;
        console.warn("No user authenticated. User might have signed out or session expired.");
        renderGame();
      }
    });

    // --- Song Selection UI Logic ---
    function renderMixer() {
      const mixerBoard = document.getElementById("mixer-board");
      if (!mixerBoard) return;

      mixerBoard.innerHTML = ''; // Clear previous state

      availableCategories.forEach(category => {
        const channel = document.createElement('div');
        channel.className = 'mixer-channel';

        const genreTitle = document.createElement('h5');
        genreTitle.className = 'genre-title';
        genreTitle.textContent = category;
        genreTitle.addEventListener('click', () => handleGenreTitleClick(category));
        
        const decadeButtons = document.createElement('div');
        decadeButtons.className = 'decade-buttons';
        decadeButtons.style.touchAction = 'none'; // Prevent scrolling while sliding on mobile

        let dragThresholdMet = false;
        let startY = 0;
        let lastDragY = 0;

        decadeButtons.addEventListener('pointerdown', (e) => {
          isDraggingMixer = true;
          dragThresholdMet = false;
          startY = e.clientY;
          lastDragY = e.clientY;
          decadeButtons.setPointerCapture(e.pointerId);
        });

        decadeButtons.addEventListener('pointermove', (e) => {
          if (!isDraggingMixer) return;
          const deltaY = e.clientY - lastDragY;
          if (Math.abs(e.clientY - startY) > 5) dragThresholdMet = true;

          if (dragThresholdMet) {
            const target = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement;
            if (target && target.classList.contains('decade-button')) {
              const year = target.dataset.year!;
              const cat = target.dataset.category!;
              if (deltaY < 0) toggleButtonState(target as HTMLButtonElement, year, cat, true); // Dragging UP selects
              else if (deltaY > 0) toggleButtonState(target as HTMLButtonElement, year, cat, false); // Dragging DOWN unselects
            }
            lastDragY = e.clientY;
          }
        });

        decadeButtons.addEventListener('pointerup', (e) => {
          if (!isDraggingMixer) return;
          decadeButtons.releasePointerCapture(e.pointerId);
          if (!dragThresholdMet) { // Process as a single click if there was barely any drag
            const target = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement;
            if (target && target.classList.contains('decade-button')) {
              const year = target.dataset.year!;
              const cat = target.dataset.category!;
              const existingIndex = currentSongSelections.findIndex(s => s.year === year && s.category === cat);
              toggleButtonState(target as HTMLButtonElement, year, cat, existingIndex === -1);
            }
          }
        });

        availableYears.forEach(year => {
          const button = document.createElement('button');
          button.className = 'decade-button';
          button.dataset.year = year;
          button.dataset.category = category;
          button.textContent = year;

          const isSelected = currentSongSelections.some(s => s.year === year && s.category === category);
          if (isSelected) {
            button.classList.add('active');
          }

          decadeButtons.appendChild(button);
        });

        channel.appendChild(decadeButtons);
        channel.appendChild(genreTitle);
        mixerBoard.appendChild(channel);
      });
    }

    function toggleButtonState(btn: HTMLButtonElement, year: string, category: string, targetState: boolean) {
      const existingIndex = currentSongSelections.findIndex(s => s.year === year && s.category === category);
      if (targetState && existingIndex === -1) {
        currentSongSelections.push({ year, category });
        btn.classList.add('active');
      } else if (!targetState && existingIndex > -1) {
        currentSongSelections.splice(existingIndex, 1);
        btn.classList.remove('active');
      }
    }

    function handleGenreTitleClick(category: string) {
      const yearsForCategory = availableYears;
      const selectionsForCategory = currentSongSelections.filter(s => s.category === category);
      const allSelected = yearsForCategory.length > 0 && yearsForCategory.length === selectionsForCategory.length;

      // First, remove all existing selections for this category
      let updatedSelections = currentSongSelections.filter(s => s.category !== category);

      if (!allSelected) {
        // If not all were selected (i.e. it was off or partially on), turn them all on.
        const newSelections = yearsForCategory.map(year => ({ year, category }));
        updatedSelections.push(...newSelections);
      }
      // If all were already selected, we've now removed them, so we do nothing more.

      currentSongSelections = updatedSelections;
      dispatchInternal({ type: "SET_SONG_SELECTIONS", selections: currentSongSelections });
    }

    // Initialize effects
    initEngineEffects(player, () => game, dispatchInternal); // Pass dispatchInternal

    // Firebase sync for multiplayer
    if (gameCode) {
      const gameRef = ref(realtimeDb, `games/${gameCode}`);
      
      onValue(gameRef, (snapshot) => {
        const data = snapshot.val();
        if (data) {
          isFirebaseLoaded = true;
          const prevGame = game;

          // sanitize players list from firebase object
          const playersArray = data.players
            ? Object.entries(data.players as Record<string, any>)
                .filter(([, p]) => p != null)
                .map(([uid, playerObj]) => ({
                  uid: uid.toString(),
                  ...playerObj
                }))
            : [];

          // clamp index values to avoid bad accesses
          if (game.turnIndex >= playersArray.length || game.turnIndex < 0) {
            console.warn("Firebase sync: turnIndex out of bounds, resetting to 0", game.turnIndex, playersArray.length);
            game.turnIndex = 0;
          }
          if (
            game.circleGuessIndex !== undefined &&
            (game.circleGuessIndex >= playersArray.length || game.circleGuessIndex < 0)
          ) {
            console.warn(
              "Firebase sync: circleGuessIndex out of bounds, resetting to 0",
              game.circleGuessIndex,
              playersArray.length
            );
            game.circleGuessIndex = 0;
          }

          // build new game state with defaults for missing fields
          game = {
            phase: data.phase ?? "LOBBY",
            mode: data.mode ?? "CLASSIC",
            readyPlayers: data.readyPlayers || [],
            skipVotes: data.skipVotes || [],
            roundWinner: data.roundWinner || null,
            players: playersArray,
            turnIndex: data.turnIndex ?? 0,
            circleGuessIndex: data.circleGuessIndex,
            currentSong: data.currentSong ?? null,
            originalGuesses: data.originalGuesses || {},
            circleGuesses: data.circleGuesses || {},
            preFireGuesses: data.preFireGuesses || {}, // Ensure preFireGuesses is loaded from Firebase
            answerRevealed: data.answerRevealed ?? false,
            guessStartTime: data.guessStartTime ?? null,
            guessTimeLimit: data.guessTimeLimit ?? 30, // Default to 30 seconds
            winner: data.winner ?? undefined, // Default to 'All/All'
            songSelections: data.songSelections || []
          };

          // Update selectedCategories from loaded game state
          if (JSON.stringify(game.songSelections) !== JSON.stringify(currentSongSelections)) {
            if (!isDraggingMixer) {
              currentSongSelections = game.songSelections || [];
              availableSongsForGame = []; // Clear song cache if selections changed
              renderMixer();
            }
          }

          // Clear inputs at the start of a new round for all clients
          if (game.phase === "SONG_PLAYING" && prevGame.phase !== "SONG_PLAYING") {
            clearGuessInputs();
          }

          console.log("Local game.players after Firebase update and transformation:", game.players);
          if (playersArray.length !== prevGame.players.length) {
            console.log("Players count changed from", prevGame.players.length, "to", playersArray.length);
          }

          handleEngineEffects(prevGame, game, player);
          // if we're in SONG_PLAYING and still have no song, check again
          if (game.phase === "SONG_PLAYING" && !game.currentSong) {
            maybeLoadNewSongIntoGame();
          }
          renderGame();
        } else {
          console.warn("Game data is null or undefined from Firebase.");
        }
      });
    }

    // UI Event Handlers

    modeSelect?.addEventListener("change", (e) => {
      const target = e.target as HTMLSelectElement;
      const host = game.players.find(p => p.isHost);
      if (host?.uid === myPlayerId) {
        dispatchInternal({ type: "SET_GAME_MODE", mode: target.value as GameMode });
      } else {
        target.value = game.mode || "CLASSIC";
      }
    });

// START GAME HANDLER
    startGameBtn.addEventListener("click", () => {
      const host = game.players.find(p => p.isHost);
      if (host?.uid !== myPlayerId) return; // only host may start
      if (game.players.length < 2) {
        alert("Need at least 2 players to start!");
        return;
      }
      const selectedSongs = filterSongs(currentSongSelections);

      if (selectedSongs.length < 50) {
        if (currentSongSelections.length === 0) {
          alert("Please select at least one song pack to start the game.");
        } else {
          alert(`Your current selection only has ${selectedSongs.length} songs. Please select at least 50 songs to start the game.`);
        }
        return;
      }

      availableSongsForGame = []; // Force fresh song list for new game
      dispatchInternal({ type: "START_GAME" });
    });

    clearMixerBtn?.addEventListener("click", () => {
      currentSongSelections = [];
      dispatchInternal({ type: "SET_SONG_SELECTIONS", selections: currentSongSelections });
    });

    selectAllBtn?.addEventListener("click", () => {
      const allSelections: SongSelection[] = [];
      availableCategories.forEach(category => {
        availableYears.forEach(year => {
          allSelections.push({ year, category });
        });
      });
      currentSongSelections = allSelections;
      dispatchInternal({ type: "SET_SONG_SELECTIONS", selections: currentSongSelections });
    });

    skipBtn.onclick = () => {
      if (game.mode === "RACE" && myPlayerId) {
        dispatchInternal({ type: "VOTE_SKIP", playerId: myPlayerId });
        return;
      }

      const origId = game.players[game.turnIndex]?.uid;
      if (gameCode && origId !== myPlayerId) return;
      if (game.phase === "SONG_PLAYING") {
        dispatchInternal({ type: "END_SONG" });
      }
    };

    playBtn.onclick = () => {
      const activeId = getActiveGuesserId();
      const isAllowed = myPlayerId === activeId && game.mode !== "RACE";
      if (gameCode && !isAllowed) {
        console.log("🔒 play/pause disabled for non-active player");
        return;
      }
      // toggle play state via reducer so it syncs to Firebase
      const currentlyPlaying = game.currentSong?.isPlaying ?? false;
      dispatchInternal({ type: "SET_PLAYING", playing: !currentlyPlaying });
    };
    submitGuessBtn.onclick = () => {
      if (!myPlayerId) return; // Can't submit without being a player

      const guesses: Guess = {};
      if (songInput.value.trim()) guesses.song = songInput.value.trim();
      if (artistInput.value.trim()) guesses.artist = artistInput.value.trim();
      if (yearInput.value.trim()) guesses.year = parseInt(yearInput.value.trim());
      if (albumInput.value.trim()) guesses.album = albumInput.value.trim();

      // Dispatch the unified SUBMIT_GUESS action for any player at any time
      dispatchInternal({
        type: "SUBMIT_GUESS",
        playerId: myPlayerId,
        guesses: guesses,
      });

      // Clear all input fields after submitting
      clearGuessInputs();
    };

    // PHASE PROGRESSION BUTTONS
    const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
    const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;
    const playAgainBtn = document.getElementById("play-again-btn") as HTMLButtonElement;

    revealBtn?.addEventListener("click", () => {
      dispatchInternal({ type: "REVEAL_ANSWERS" });
    });

    resolveBtn?.addEventListener("click", () => {
      if (game.mode === "RACE" && myPlayerId) {
        dispatchInternal({ type: "PLAYER_READY", playerId: myPlayerId });
      } else {
        dispatchInternal({ type: "RESOLVE_ROUND" });
      }
    });

    playAgainBtn?.addEventListener("click", () => {
      const host = game.players.find(p => p.isHost);
      if (host?.uid !== myPlayerId) return; // only the host can choose to play again
      availableSongsForGame = []; // Ensure fresh song list for next game
      dispatchInternal({ type: "START_GAME" });
    });

    // Render game state to UI
    function renderGame() {
      
      console.log("Rendering game. Current players in renderGame():", game.players);

      const statusEl = document.getElementById("game-status");
      const turnIndicator = document.getElementById("turn-indicator");
      const playerListEl = document.getElementById("player-list");
      const resultsEl = document.getElementById("results");
      const mixerContainer = document.getElementById("song-mixer-container");
      const lobbyControls = document.getElementById("lobby-controls");
      const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
      const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;
      const playAgainBtn = document.getElementById("play-again-btn") as HTMLButtonElement;

      const activeId = getActiveGuesserId();

      // Auto-submit pre-fired guess if it is my turn
      if ((game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN") && activeId === myPlayerId) {
        if (game.preFireGuesses[myPlayerId] !== undefined) {
          console.log("Auto-submitting pre-fired guess for", myPlayerId);
          setTimeout(() => {
            dispatchInternal({
              type: "SUBMIT_GUESS",
              playerId: myPlayerId!,
              guesses: game.preFireGuesses[myPlayerId!]
            });
          }, 0);
        }
      }

      if (!statusEl || !playerListEl || !resultsEl) return;

      // ADD THIS: Reset song flag when entering SONG_PLAYING phase
      if (game.phase === "SONG_PLAYING" && songPlayedThisRound) {
        songPlayedThisRound = false;
      }

      // HIDE LOBBY CONTROLS WHEN GAME STARTS
      if (lobbyControls) {
        lobbyControls.style.display = game.phase === "LOBBY" ? "block" : "none";
      }
      // show / hide start button and disable for non-hosts
      const host = game.players.find(p => p.isHost);
      if (startGameBtn) {
        if (host?.uid !== myPlayerId) {
          startGameBtn.style.display = "none";
        } else {
          startGameBtn.style.display = "inline-block";
        }
        startGameBtn.disabled = game.players.length < 2;
      }
      if (modeSelect) {
        modeSelect.value = game.mode || "CLASSIC";
        modeSelect.disabled = host?.uid !== myPlayerId;
      }

      // Update song selection controls visibility based on lobby phase
      if (mixerContainer) {
        if (game.phase === "LOBBY") {
          mixerContainer.style.display = 'block';
          if (!isDraggingMixer) renderMixer(); // Re-render to reflect current state
        } else {
          mixerContainer.style.display = 'none';
        }
      }

      const phaseDisplay = game.phase || "LOBBY";
      statusEl.textContent = `Phase: ${phaseDisplay}`;
      
    if (game.players.length > 0) {
      // make sure indices are valid to avoid undefined access
      if (game.turnIndex >= game.players.length || game.turnIndex < 0) {
        console.warn("renderGame: turnIndex out of bounds", game.turnIndex, game.players.length);
      }
      const currentPlayer = game.players[game.turnIndex] || { name: "(none)" };
      statusEl.textContent += ` | Original Guesser: ${currentPlayer.name}`;
      
      // Show circle guesser
      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        if (game.circleGuessIndex >= game.players.length || game.circleGuessIndex < 0) {
          console.warn("renderGame: circleGuessIndex out of bounds", game.circleGuessIndex, game.players.length);
        }
        const circlePlayer = game.players[game.circleGuessIndex] || { name: "(none)" };
        statusEl.textContent += ` | Circle Turn: ${circlePlayer.name}`;
      }
    } // End of if (game.players.length > 0)

      // Update player list, marking host
      playerListEl.innerHTML = game.players
      .map(p => {

        const isActive = p.uid === activeId;

        return `
        <div class="player-card ${isActive ? "active-player" : ""}">

          <div class="player-row">

            <div class="avatar">
              ${p.name ? p.name[0].toUpperCase() : "?"}
            </div>

            <div class="player-info">
              <div class="player-name">
                ${p.name || "Unknown"} ${p.isHost ? "👑" : ""}
              </div>

              <div class="health-bar">
                <div class="health-fill" style="width:${p.health}%"></div>
              </div>

            </div>

          </div>

        </div>
        `;
      })
      .join("");

      // Show/hide guess form based on phase.
      const isGuessingPhase = game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN" || (game.phase === "SONG_PLAYING" && game.mode === "RACE");
      
      // Determine if the local player has already submitted a guess for this round.
      // We check preFireGuesses (staged), originalGuesses (processed), and circleGuesses (processed).
      const hasGuessed = myPlayerId && game.mode !== "RACE" && (
        game.preFireGuesses[myPlayerId] !== undefined || 
        game.originalGuesses[myPlayerId] !== undefined || 
        game.circleGuesses[myPlayerId] !== undefined
      );

      const activePlayer = game.players.find(p => p.uid === activeId);
      if (turnIndicator) {
        if (game.mode === "RACE") {
          turnIndicator.textContent = "🏎️ RACE MODE - Fastest guess wins!";
        } else if (activePlayer) {
          turnIndicator.textContent = `🎤 ${activePlayer.name}'s Turn`;
        } else {
          turnIndicator.textContent = "";
        }
      }

      if (isGuessingPhase && myPlayerId && !hasGuessed) {
        guessForm.style.display = "block";
        updateSubmitButtonText();
      } else {
        guessForm.style.display = "none";
      }

      // Update and display guess timer
      const isRacePostSong = game.phase === "SONG_PLAYING" && game.mode === "RACE" && game.guessStartTime !== null;
      if ((game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN" || isRacePostSong) && game.guessStartTime !== null) {
        guessTimerEl.style.display = "block";
        if (guessCountdownInterval) {
          clearInterval(guessCountdownInterval);
        }
        guessCountdownInterval = setInterval(() => {
          const elapsed = Math.floor((Date.now() - game.guessStartTime!) / 1000);
          const remaining = Math.max(0, game.guessTimeLimit - elapsed);
          guessTimerEl.textContent = `Time left: ${remaining}s`;
          if (remaining <= 0) {
            clearInterval(guessCountdownInterval!);
            guessCountdownInterval = null;
            // The GUESS_TIMEOUT action is dispatched by engine.effects.ts
          }
        }, 1000);
      } else {
        if (guessCountdownInterval) clearInterval(guessCountdownInterval);
        guessTimerEl.style.display = 'none';
      }

      // Show results
      if (game.phase === "REVEAL_RESULTS" && game.currentSong) {
        let raceWinnerText = "";
        if (game.mode === "RACE") {
          const winner = game.players.find(p => String(p.uid) === game.roundWinner);
          raceWinnerText = winner 
            ? `<h2 style="color: #42d67d;">🏎️ ${winner.name} got the right answer!</h2>` 
            : `<h2 style="color: #ff4136;">No one guessed it!</h2>`;
        }
        resultsEl.innerHTML = `
          ${raceWinnerText}
          <h3>Answer:</h3>
          <p>Song: ${game.currentSong.displayName}</p>
          <p>Artist: ${game.currentSong.displayArtists}</p>
          <p>Year: ${game.currentSong.year}</p>
          <p>Album: ${game.currentSong.album}</p>
        `;
      } else {
        resultsEl.innerHTML = "";
      }

      // Show game over screen
      if (game.phase === "GAME_OVER") {
        const winner = game.players.find(p => p.uid === game.winner);
        
        let raceWinnerText = "";
        if (game.mode === "RACE" && game.roundWinner) {
          const roundWinner = game.players.find(p => String(p.uid) === game.roundWinner);
          if (roundWinner) {
            raceWinnerText = `<h3 style="color: #42d67d;">🏎️ ${roundWinner.name} got the final answer!</h3>`;
          }
        }
        let songInfo = "";
        if (game.currentSong) {
          songInfo = `
            ${raceWinnerText}
            <h3>Final Answer:</h3>
            <p>Song: ${game.currentSong.displayName}</p>
            <p>Artist: ${game.currentSong.displayArtists}</p>
            <p>Year: ${game.currentSong.year}</p>
            <p>Album: ${game.currentSong.album}</p>
          `;
        }
        resultsEl.innerHTML = `
          <h2 style="font-size: 3rem; text-shadow: 0 0 10px #ff00ff;">🎉 GAME OVER 🎉</h2>
          <h2 style="color: #00eaff;">${winner ? `👑 ${winner.name} wins the game! 👑` : "It's a draw!"}</h2>
          ${songInfo}
        `;
      }

      // Control button visibility based on phase
      if (revealBtn) revealBtn.style.display = 
        game.phase === "WAITING_TO_REVEAL" ? "block" : "none";
      
      if (resolveBtn) {
        resolveBtn.style.display = game.phase === "REVEAL_RESULTS" ? "block" : "none";
        if (game.mode === "RACE" && myPlayerId) {
          const isReady = game.readyPlayers?.includes(myPlayerId);
          resolveBtn.textContent = isReady ? "Waiting for others..." : "Ready Up";
          resolveBtn.disabled = isReady;
        } else {
          resolveBtn.textContent = "Continue to Next Round";
          resolveBtn.disabled = false;
        }
      }

      if (playAgainBtn) {
        playAgainBtn.style.display = (game.phase === "GAME_OVER" && host?.uid === myPlayerId) ? "block" : "none";
      }

      // Enable/disable music controls based on phase and active guesser
      const me = game.players.find(p => p.uid === myPlayerId);

      const musicControls = document.getElementById("music-controls");
      if (musicControls) {
        musicControls.style.display = game.phase === "SONG_PLAYING" ? "block" : "none";
      }

      if (playBtn) { // Ensure playBtn exists
        const isGuesser = activeId === myPlayerId;
        playBtn.disabled = (game.phase === "SONG_PLAYING" && isGuesser && game.mode !== "RACE") ? false : true;
        playBtn.style.display = (game.phase === "SONG_PLAYING" && game.mode !== "RACE") ? "inline-block" : "none";
      }

      const origGuesserId = game.players[game.turnIndex]?.uid;
      if (skipBtn) {
        if (game.mode === "RACE") {
          const alivePlayers = game.players.filter(p => p.alive).length;
          const hasVoted = !!(myPlayerId && game.skipVotes?.includes(myPlayerId));
          skipBtn.style.display = game.phase === "SONG_PLAYING" && myPlayerId && game.players.find(p => p.uid === myPlayerId)?.alive ? "inline-block" : "none";
          skipBtn.textContent = hasVoted ? `Skip (${game.skipVotes?.length || 0}/${alivePlayers})` : "Vote Skip";
          skipBtn.disabled = hasVoted;
        } else {
          skipBtn.style.display = (
            game.phase === "SONG_PLAYING" &&
            game.currentSong &&
            game.currentSong.hasBeenPlayed &&
            origGuesserId === myPlayerId
          ) ? "inline-block" : "none";
          skipBtn.textContent = "Skip Song";
          skipBtn.disabled = false;
        }

      }

      if (playBtn) { // Ensure playBtn exists before accessing its properties
        // reflect play button based on state
        if (game.currentSong?.isPlaying) {
          playBtn.textContent = "⏸";
        } else {
          playBtn.textContent = "▶";
        }
      }
    }

    // Initial render
    renderGame();
  });
</script>

