---
interface Props {
  gameCode?: string;
}
const { gameCode = "" } = Astro.props;
---

<div id="game-container" data-game-code={gameCode}>
  <!-- Game Status Display -->
  <div id="game-status"></div>
  <div id="turn-indicator"></div>

  <!-- ADD PLAYER NAME INPUT -->
  <div id="lobby-controls">
    <button id="start-game">Start Game</button>
  </div>
  
  <!-- Player List -->
  <div id="player-list"></div>
  
  <!-- Music Player Controls -->
  <div id="music-controls">
  <button id="playBtn">▶</button>
  <button id="skip-btn" style="display:none">⏭ Skip</button>
  <audio id="player"></audio>

  <div id="song-progress">
    <div id="song-progress-bar"></div>
  </div>
</div>

  <!-- Guess Form -->
  <div id="guess-form" style="display: none;">
    <input id="song-input" placeholder="Song name" />
    <input id="artist-input" placeholder="Artist" />
    <input id="year-input" type="number" placeholder="Year" />
    <input id="album-input" placeholder="Album" />
    <button id="submit-guess">Submit Guess</button>
  </div>
  
  <!-- Results Display -->
  <div id="results"></div>
  
  <!-- Phase Control Buttons -->
  <div id="phase-controls">
    <button id="reveal-btn" style="display: none;">Reveal Answers</button>
    <button id="resolve-btn" style="display: none;">Continue to Next Round</button>
  </div>
</div>

<script>
  import { gameReducer, type Game, type GameAction } from "../game.logic/engine";
  import { initEngineEffects, handleEngineEffects } from "../game.logic/engine.effects";
  import { onAuthStateChanged } from "firebase/auth"; // Import authentication functions
  import type { User } from "firebase/auth"
  import { ref, set, onValue, push, update } from "firebase/database"; // Import Realtime Database specific functions
  import { realtimeDb, analytics, auth } from "../libraries/firebase";

  let currentUser: User | null = null; // Declare currentUser globally
  let myPlayerId: string | null = null; // To store the UID of the current user's player



  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("game-container");
    const playBtn = document.getElementById("playBtn") as HTMLButtonElement;
    const skipBtn = document.getElementById("skip-btn") as HTMLButtonElement;
    const player = document.getElementById("player") as HTMLAudioElement;
    const progressBar = document.getElementById("song-progress-bar") as HTMLDivElement;
    const guessForm = document.getElementById("guess-form") as HTMLDivElement;
    const submitGuessBtn = document.getElementById("submit-guess") as HTMLButtonElement;
    const startGameBtn = document.getElementById("start-game") as HTMLButtonElement;
    const gameCode = container?.getAttribute("data-game-code") ?? "";
    if (!gameCode) {
      console.error("No game code found");
      return;
    }

    player.addEventListener("timeupdate", () => {
      if (!progressBar || !player.duration) return;

      const percent = (player.currentTime / player.duration) * 100;
      progressBar.style.width = percent + "%";
    });

    // Song fetching logic (from MusicPlayer)
    const playedTrackIds = new Set<number>();
    let availableSongs: any[] = [];
    let currentOffset = 0;
    const PAGE_LIMIT = 200;
    const SEARCH_TERM = "pop";

    async function loadSongs(): Promise<void> {
      const url = `https://itunes.apple.com/search?term=${encodeURIComponent(
        SEARCH_TERM
      )}&media=music&entity=song&limit=${PAGE_LIMIT}&offset=${currentOffset}`;

      const response = await fetch(url);
      const data = await response.json();

      if (!data.results || data.results.length === 0) {
        throw new Error("No more songs found 😢");
      }

      const fresh = data.results.filter(
        (song: any) => song.previewUrl && !playedTrackIds.has(song.trackId)
      );

      currentOffset += PAGE_LIMIT;

      if (fresh.length === 0) {
        return loadSongs();
      }

      availableSongs = fresh;
    }

    async function getNextSong() {
      if (availableSongs.length === 0) {
        await loadSongs();
      }

      const index = Math.floor(Math.random() * availableSongs.length);
      const [song] = availableSongs.splice(index, 1);
      playedTrackIds.add(song.trackId);
      
      // Convert iTunes format to your Game format
      return {
        name: song.trackName,
        artist: song.artistName,
        year: new Date(song.releaseDate).getFullYear(),
        album: song.collectionName || "Unknown Album",
        previewURL: song.previewUrl
      };
    }

    // Initialize game state
    let game: Game = {
      phase: "LOBBY",
      players: [],
      turnIndex: 0,
      currentSong: null,
      originalGuesses: {},
      circleGuesses: {},
      answerRevealed: false
    };

    // helper to figure out whose turn it is to guess
    function getActiveGuesserId(): string | null {
      if (game.phase === "SONG_PLAYING") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "ORIGINAL_GUESS_TURN") {
        return game.players[game.turnIndex]?.uid?.toString() ?? null;
      }

      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        return game.players[game.circleGuessIndex]?.uid?.toString() ?? null;
      }

      return null;
    }

    // retained for legacy logic but no longer tied to UI
  let songPlayedThisRound = false;

    function dispatch(action: GameAction) {
      const prevGame = game;
      game = gameReducer(game, action);

      // Handle side effects
      handleEngineEffects(prevGame, game, player);

      // Update UI
      renderGame();

      // Sync to Firebase if multiplayer
      if (gameCode) {
        const gameRef = ref(realtimeDb, `games/${gameCode}`);
        // Firestore/RealtimeDB rejects undefined values.
        let gameToWrite: any = JSON.parse(JSON.stringify(game));
        if (gameToWrite.circleGuessIndex === undefined) {
          delete gameToWrite.circleGuessIndex;
        }
        try {
          set(gameRef, gameToWrite);
        } catch (err) {
          console.error("Failed to sync game to Firebase", err, gameToWrite);
        }
      }
    }

    // helper to load song when phase is SONG_PLAYING and none yet
    async function maybeLoadSong() {
      console.log("maybeLoadSong invoked", { phase: game.phase, currentSong: !!game.currentSong, myPlayerId });
      if (!myPlayerId) return;
      if (game.phase === "SONG_PLAYING" && !game.currentSong) {
        const origGuesserId = game.players[game.turnIndex]?.uid;
        const host = game.players.find(p => p.isHost)?.uid;
        if (myPlayerId === origGuesserId || myPlayerId === host) {
          console.log("maybeLoadSong deciding to fetch (orig or host)", { origGuesserId, host });
          try {
            const song = await getNextSong();
            dispatch({ type: "PLAY_SONG", song: { ...song, isPlaying: false } });
          } catch (err) {
            console.error("Failed to load initial song", err);
          }
        } else {
          console.log("maybeLoadSong - not authorized to fetch", { origGuesserId, host });
        }
      }
    }

    // authentication observer moved inside DOMContentLoaded so dispatch is available
    onAuthStateChanged(auth, (user) => {
      if (user) {
        currentUser = user;
        myPlayerId = user.uid; // Store the UID
        console.log("Game component: Authenticated user UID:", myPlayerId);
        maybeLoadSong(); // try load if phase already started
      } else {
        currentUser = null;
        myPlayerId = null;
        console.warn("Game component: No user authenticated. User might have signed out or session expired.");
      }
    });
    // Initialize effects
    initEngineEffects(player, () => game, dispatch);

    // Firebase sync for multiplayer
    if (gameCode) {
      const gameRef = ref(realtimeDb, `games/${gameCode}`);
      
      onValue(gameRef, (snapshot) => {
        const data = snapshot.val();
        if (data) {
          const prevGame = game;

          // sanitize players list from firebase object
          const playersArray = data.players
            ? Object.entries(data.players as Record<string, any>)
                .filter(([, p]) => p != null)
                .map(([uid, playerObj]) => ({
                  uid: uid.toString(),
                  ...playerObj
                }))
            : [];

          // clamp index values to avoid bad accesses
          if (game.turnIndex >= playersArray.length || game.turnIndex < 0) {
            console.warn("Firebase sync: turnIndex out of bounds, resetting to 0", game.turnIndex, playersArray.length);
            game.turnIndex = 0;
          }
          if (
            game.circleGuessIndex !== undefined &&
            (game.circleGuessIndex >= playersArray.length || game.circleGuessIndex < 0)
          ) {
            console.warn(
              "Firebase sync: circleGuessIndex out of bounds, resetting to 0",
              game.circleGuessIndex,
              playersArray.length
            );
            game.circleGuessIndex = 0;
          }

          // build new game state with defaults for missing fields
          game = {
            phase: data.phase ?? "LOBBY",
            players: playersArray,
            turnIndex: data.turnIndex ?? 0,
            circleGuessIndex: data.circleGuessIndex,
            currentSong: data.currentSong ?? null,
            originalGuesses: data.originalGuesses || {},
            circleGuesses: data.circleGuesses || {},
            answerRevealed: data.answerRevealed ?? false,
            winner: data.winner ?? undefined
          };

          console.log("Local game.players after Firebase update and transformation:", game.players);
          if (playersArray.length !== prevGame.players.length) {
            console.log("Players count changed from", prevGame.players.length, "to", playersArray.length);
          }

          handleEngineEffects(prevGame, game, player);
          // if we're in SONG_PLAYING and still have no song, check again
          if (game.phase === "SONG_PLAYING" && !game.currentSong) {
            maybeLoadSong();
          }
          renderGame();
        } else {
          console.warn("Game data is null or undefined from Firebase.");
        }
      });
    }

    // UI Event Handlers

// START GAME HANDLER
    startGameBtn.addEventListener("click", () => {
      const host = game.players.find(p => p.isHost);
      if (host?.uid !== myPlayerId) return; // only host may start
      if (game.players.length < 2) {
        alert("Need at least 2 players to start!");
        return;
      }
      dispatch({ type: "START_GAME" });
    });



    playBtn.onclick = () => {
      // only the active guesser may toggle play/pause
      const activeId = getActiveGuesserId();
      if (gameCode && myPlayerId !== activeId) {
        console.log("🔒 play/pause disabled for non-active player");
        return;
      }
      // toggle play state via reducer so it syncs to Firebase
      const currentlyPlaying = game.currentSong?.isPlaying ?? false;
      dispatch({ type: "SET_PLAYING", playing: !currentlyPlaying });
    };

    skipBtn.onclick = () => {
      // only the original guesser may skip
      const origId = game.players[game.turnIndex]?.uid;
      if (gameCode && origId !== myPlayerId) return;
      if (game.phase === "SONG_PLAYING") {
        dispatch({ type: "END_SONG" });
      }
    };
    submitGuessBtn.onclick = () => {
      const songInput = document.getElementById("song-input") as HTMLInputElement;
      const artistInput = document.getElementById("artist-input") as HTMLInputElement;
      const yearInput = document.getElementById("year-input") as HTMLInputElement;
      const albumInput = document.getElementById("album-input") as HTMLInputElement;

      const song = songInput.value;
      const artist = artistInput.value;
      const year = parseInt(yearInput.value);
      const album = albumInput.value;

      const activeId = getActiveGuesserId();
      if (game.phase === "ORIGINAL_GUESS_TURN") {
        if (activeId !== myPlayerId) return; // ignore others
        dispatch({
          type: "ORIGINAL_GUESS_SUBMIT",
          guesses: { song, artist, year, album }
        });
      } else if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        if (activeId !== myPlayerId) return;
        const currentCirclePlayer = game.players[game.circleGuessIndex];
        dispatch({
          type: "CIRCLE_GUESS_SUBMIT",
          playerId: currentCirclePlayer.uid as number,
          guesses: { song, artist, year, album }
        });
      }

      // Clear all input fields after submitting
      songInput.value = "";
      artistInput.value = "";
      yearInput.value = "";
      albumInput.value = "";
    };

    // PHASE PROGRESSION BUTTONS
    const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
    const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;

    revealBtn?.addEventListener("click", () => {
      dispatch({ type: "REVEAL_ANSWERS" });
    });

    resolveBtn?.addEventListener("click", () => {
      dispatch({ type: "RESOLVE_ROUND" });
      setTimeout(() => renderGame(), 10);
    });

    // Render game state to UI
    function renderGame() {
      
      console.log("Rendering game. Current players in renderGame():", game.players);

      const statusEl = document.getElementById("game-status");
      const turnIndicator = document.getElementById("turn-indicator");
      const playerListEl = document.getElementById("player-list");
      const resultsEl = document.getElementById("results");
      const lobbyControls = document.getElementById("lobby-controls");
      const revealBtn = document.getElementById("reveal-btn") as HTMLButtonElement;
      const resolveBtn = document.getElementById("resolve-btn") as HTMLButtonElement;

      if (!statusEl || !playerListEl || !resultsEl) return;

      // ADD THIS: Reset song flag when entering SONG_PLAYING phase
      if (game.phase === "SONG_PLAYING" && songPlayedThisRound) {
        songPlayedThisRound = false;
      }

      // HIDE LOBBY CONTROLS WHEN GAME STARTS
      if (lobbyControls) {
        lobbyControls.style.display = game.phase === "LOBBY" ? "block" : "none";
      }
      // show / hide start button and disable for non-hosts
      const host = game.players.find(p => p.isHost);
      if (startGameBtn) {
        if (host?.uid !== myPlayerId) {
          startGameBtn.style.display = "none";
        } else {
          startGameBtn.style.display = "inline-block";
        }
        startGameBtn.disabled = game.players.length < 2;
      }

      // Update phase display (fallback to LOBBY if DB missing)
      const phaseDisplay = game.phase || "LOBBY";
      statusEl.textContent = `Phase: ${phaseDisplay}`;

    if (game.players.length > 0) {
      // make sure indices are valid to avoid undefined access
      if (game.turnIndex >= game.players.length || game.turnIndex < 0) {
        console.warn("renderGame: turnIndex out of bounds", game.turnIndex, game.players.length);
      }
      const currentPlayer = game.players[game.turnIndex] || { name: "(none)" };
      statusEl.textContent += ` | Original Guesser: ${currentPlayer.name}`;
      
      // Show circle guesser
      if (game.phase === "CIRCLE_GUESS_TURN" && game.circleGuessIndex !== undefined) {
        if (game.circleGuessIndex >= game.players.length || game.circleGuessIndex < 0) {
          console.warn("renderGame: circleGuessIndex out of bounds", game.circleGuessIndex, game.players.length);
        }
        const circlePlayer = game.players[game.circleGuessIndex] || { name: "(none)" };
        statusEl.textContent += ` | Circle Turn: ${circlePlayer.name}`;
      }
    }

      // Update player list, marking host
      playerListEl.innerHTML = game.players
      .map(p => {

        const activeId = getActiveGuesserId();
        const isActive = p.uid === activeId;

        return `
        <div class="player-card ${isActive ? "active-player" : ""}">

          <div class="player-row">

            <div class="avatar">
              ${p.name ? p.name[0].toUpperCase() : "?"}
            </div>

            <div class="player-info">
              <div class="player-name">
                ${p.name || "Unknown"} ${p.isHost ? "👑" : ""}
              </div>

              <div class="health-bar">
                <div class="health-fill" style="width:${p.health}%"></div>
              </div>

            </div>

          </div>

        </div>
        `;
      })
      .join("");

      // Show/hide guess form based on phase *and* active guesser
      const activeId = getActiveGuesserId();
      const activePlayer = game.players.find(p => p.uid === activeId);
      if (turnIndicator) {
        if (activePlayer) {
          turnIndicator.textContent = `🎤 ${activePlayer.name}'s Turn`;
        } else {
          turnIndicator.textContent = "";
        }
      }
      if (
        (game.phase === "ORIGINAL_GUESS_TURN" || game.phase === "CIRCLE_GUESS_TURN") &&
        activeId === myPlayerId
      ) {
        guessForm.style.display = "block";
      } else {
        guessForm.style.display = "none";
      }

      // Show results
      if (game.phase === "REVEAL_RESULTS" && game.currentSong) {
        resultsEl.innerHTML = `
          <h3>Answer:</h3>
          <p>Song: ${game.currentSong.name}</p>
          <p>Artist: ${game.currentSong.artist}</p>
          <p>Year: ${game.currentSong.year}</p>
          <p>Album: ${game.currentSong.album}</p>
        `;
      } else {
        resultsEl.innerHTML = "";
      }

      // Show game over screen
      if (game.phase === "GAME_OVER") {
        const winner = game.players.find(p => p.uid === game.winner);
        resultsEl.innerHTML = `
          <h2>🎉 Game Over! 🎉</h2>
          <p>${winner ? `${winner.name} wins!` : "No winner"}</p>
        `;
      }

      // Control button visibility based on phase
      if (revealBtn) revealBtn.style.display = 
        game.phase === "WAITING_TO_REVEAL" ? "block" : "none";
      
      if (resolveBtn) resolveBtn.style.display = 
        game.phase === "REVEAL_RESULTS" ? "block" : "none";

      // Enable/disable music controls based on phase, host status and active guesser
      const me = game.players.find(p => p.uid === myPlayerId);
      const isHost = me?.isHost;
      // activeId already computed above when showing the guess form
      playBtn.disabled = gameCode ? myPlayerId !== activeId : false;

      // hide play button when not listening
      playBtn.style.display = game.phase === "SONG_PLAYING" ? "inline-block" : "none";

      // show skip button only when a song is loaded and only for the original
      // guesser (turn player) while listening
      const origGuesserId = game.players[game.turnIndex]?.uid;
      if (skipBtn) {
        skipBtn.style.display =
          game.phase === "SONG_PLAYING" &&
          game.currentSong &&
          origGuesserId === myPlayerId
            ? "inline-block"
            : "none";
      }

      // reflect play button based on state
      if (game.currentSong?.isPlaying) {
        playBtn.textContent = "⏸";
      } else {
        playBtn.textContent = "▶";
      }
    }  // ← Function closes HERE, not earlier

    // Initial render
    renderGame();
  });
</script>

<style>
  /* IDs are fine as-is since they're in static HTML */
  #turn-indicator { ... }
  #song-progress { ... }
  #song-progress-bar { ... }
  #player-list { ... }
  #playBtn { ... }

  /* These need :global() because they're created via innerHTML */
  :global(.player-card) {
    background: #2a2a2a;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 10px;
    transition: all .2s;
  }
  :global(.player-row) {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  :global(.avatar) {
    width: 36px;
    height: 36px;
    background: #4c7cff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }
  :global(.player-info) { flex: 1; }
  :global(.player-name) {
    font-weight: 600;
    margin-bottom: 4px;
  }
  :global(.health-bar) {
    height: 6px;
    background: #444;
    border-radius: 10px;
    overflow: hidden;
  }
  :global(.health-fill) {
    height: 100%;
    background: #42d67d;
    transition: width .4s ease;
  }
  :global(.active-player) {
    border: 2px solid #4c7cff;
    box-shadow: 0 0 12px rgba(76,124,255,.6);
  }
  :global(.dead-player) {
    opacity: 0.5;
    filter: grayscale(100%);
  }
</style>