---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';

---

<Layout>

	<div id="container">
		<Welcome />
		<!-- Player Name Input -->
		<div id="name-section">
			<input 
				type="text" 
				id="player-name" 
				placeholder="Enter your name"
				maxlength="20"
			/>
		</div>

        <!-- will be shown during name step -->
        <button id="submitNameBtn" type="button" style="display:none">Submit Name</button>

        <div id="joinForm">
            <input 
                type="text" 
                id="gameCode" 
                placeholder="Enter game code"
                maxlength="6"
            />
            <button id="submitCodeBtn" type="button">Join Game</button>
        </div>
        <button id="createBtn" type="button">Create Game</button>
	</div>
</Layout>

<script>
	import { ref, set, get, update } from "firebase/database";
	import { realtimeDb, auth } from "../libraries/firebase";
	import { signInAnonymously, onAuthStateChanged } from "firebase/auth";
	import type { User } from "firebase/auth"

	let currentUser: User | null = null;
	let playerName: string = "";

	onAuthStateChanged(auth, (user) => {
		currentUser = user;
		if (user) {
			console.log("Landing page authenticated as:", user.uid);
		} else {
			console.log("Landing page not authenticated.");
			signInAnonymously(auth)
				.then(userCredential => {
					currentUser = userCredential.user;
					console.log("Signed in anonymously during auth state change:", currentUser.uid);
				})
				.catch(error => {
					console.error("Error signing in anonymously during auth state change:", error);
					alert("Could not authenticate. Please check your internet connection.");
				});
		}
	});


	async function ensureAuthenticatedUserUid(): Promise<string> {
        
		await new Promise(resolve => setTimeout(resolve, 50)); // Wait a bit before checking again

		if (!currentUser) {
			try {
				const userCredential = await signInAnonymously(auth);
				currentUser = userCredential.user;
			} catch (error) {
				console.error("Anonymous sign-in failed on landing page:", error);
				throw new Error("Authentication required to join or create a game.");
			}
		}
		if (!currentUser?.uid) {
			throw new Error("Authenticated user has no UID.");
		}
		return currentUser.uid;
	}

	function generateRoomCode(length = 6): string {
		const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
		let result = "";
		for (let i = 0; i < length; i++) {
			result += chars[Math.floor(Math.random() * chars.length)];
		}
		return result;
	}

	document.addEventListener("DOMContentLoaded", () => {
        const playerNameInput = document.getElementById("player-name") as HTMLInputElement;
        const nameSection = document.getElementById("name-section") as HTMLDivElement;
        const submitNameBtn = document.getElementById("submitNameBtn") as HTMLButtonElement;
        const createBtn = document.getElementById("createBtn") as HTMLButtonElement;
        const gameCodeInput = document.getElementById("gameCode") as HTMLInputElement;
        const submitCodeBtn = document.getElementById("submitCodeBtn") as HTMLButtonElement;
        const joinForm = document.getElementById("joinForm") as HTMLDivElement;

        if (!createBtn || !gameCodeInput || !submitCodeBtn || !playerNameInput || !nameSection || !submitNameBtn || !joinForm) return;

        // make sure inline style matches the CSS hiding so computed checks are reliable
        nameSection.style.display = "none";
        submitNameBtn.style.display = "none";

        // Update playerName when input changes
        playerNameInput.addEventListener("input", (e) => {
            playerName = (e.target as HTMLInputElement).value.trim();
        });

        // state tracking for two-step flows
        let pendingCode = "";            // holds code when join flow started
        let awaitingNameFor: "create" | "join" | "" = "";

        function showNameInput() {
            // hide everything except name section and submit name button
            nameSection.style.display = "block";
            createBtn.style.display = "none";
            joinForm.style.display = "none";

            submitNameBtn.style.display = "inline-block";
            playerNameInput.focus();
        }

        createBtn.addEventListener("click", async () => {
            const hidden = getComputedStyle(nameSection).display === "none";
            // first click should reveal the name field if hidden
            if (hidden) {
                awaitingNameFor = "create";
                showNameInput();
                return;
            }
            // after this point, createBtn will be hidden so this branch won't run again
        });

        async function submitCode() {
            // helper flow when name already entered and pendingCode set
            if (!gameCodeInput || !submitCodeBtn) return;

            const hidden = getComputedStyle(nameSection).display === "none";
            // if name is not yet visible we are in validation stage
            if (hidden) {
                const code = gameCodeInput.value.trim();
                if (!code) return;
                // check existence
                const exists = await checkCodeExists(code);
                if (!exists) {
                    alert("Game not found");
                    return;
                }
                pendingCode = code.toUpperCase();
                awaitingNameFor = "join";
                showNameInput();
                return;
            }
            // won't reach here; submitCodeBtn is hidden once name input shown
        }

        submitCodeBtn.addEventListener("click", submitCode);

        // final submission after entering name
        submitNameBtn.addEventListener("click", async () => {
            if (!playerName) {
                alert("Please enter your name");
                return;
            }
            submitNameBtn.disabled = true;
            try {
                if (awaitingNameFor === "create") {
                    const code = await createGame(playerName);
                    window.location.href = `game?code=${encodeURIComponent(code)}`;
                } else if (awaitingNameFor === "join") {
                    const code = pendingCode;
                    const ok = await joinGame(code, playerName);
                    if (ok) {
                        window.location.href = `game?code=${encodeURIComponent(code)}`;
                    } else {
                        alert("Game not found or you're already in it.");
                        submitNameBtn.disabled = false;
                    }
                }
            } catch (err) {
                console.error(err);
                alert("Failed to proceed. Check your connection and try again.");
                submitNameBtn.disabled = false;
            }
        });

        async function checkCodeExists(code: string): Promise<boolean> {
            const normalized = code.trim().toUpperCase();
            if (!normalized) return false;
            const gameRef = ref(realtimeDb, `games/${normalized}`);
            const snapshot = await get(gameRef);
            return snapshot.exists();
        }
    });

	async function createGame(name: string): Promise<string> {
		const hostId = await ensureAuthenticatedUserUid();
		let code = generateRoomCode();
		let gameRef = ref(realtimeDb, `games/${code}`);
		let snapshot = await get(gameRef);
		// ensure unique code
		while (snapshot.exists()) {
			code = generateRoomCode();
			gameRef = ref(realtimeDb, `games/${code}`);
			snapshot = await get(gameRef);
		}

		// write full initial game state in one shot
		const initialState = {
			phase: "LOBBY",
			turnIndex: 0,
			currentSong: null,
			originalGuesses: {},
			circleGuesses: {},
			answerRevealed: false,
			players: {
				[hostId]: {
					name: name,
					isHost: true,
					joinedAt: Date.now(),
					health: 100,
					alive: true
				}
			}
		};

		await set(gameRef, initialState);
		return code;
	}


    async function joinGame(code: string, name: string): Promise<boolean> {
        const normalizedCode = code.trim().toUpperCase();
        if (!normalizedCode) return false;

        const playerId = await ensureAuthenticatedUserUid();
        const gameRef = ref(realtimeDb, `games/${normalizedCode}`);
        const snapshot = await get(gameRef);

        if (!snapshot.exists()) {
            console.log("Game does not exist:", normalizedCode);
            return false;
        }

        const gameData = snapshot.val();
        // if this is an old game there may be missing metadata; patch minimal defaults
        const defaults: any = {};
        if (gameData.phase === undefined) defaults.phase = "LOBBY";
        if (gameData.turnIndex === undefined) defaults.turnIndex = 0;
        if (gameData.currentSong === undefined) defaults.currentSong = null;
        if (gameData.originalGuesses === undefined) defaults.originalGuesses = {};
        if (gameData.circleGuesses === undefined) defaults.circleGuesses = {};
        if (gameData.answerRevealed === undefined) defaults.answerRevealed = false;
        if (Object.keys(defaults).length) {
            await update(gameRef, defaults);
        }

        if (gameData.players && gameData.players[playerId]) {
            console.log("Player already in game:", playerId);
            return true;
        }

        const playersRef = ref(realtimeDb, `games/${normalizedCode}/players/${playerId}`);
        await set(playersRef, {
            name: name,
            isHost: false,
            joinedAt: Date.now(),
            health: 100,
            alive: true
        });
        return true;
    }
    
</script>

<style>
	
	#container {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		gap: 2rem;
	}

	#createBtn,
	#submitCodeBtn {
		font-family: "Tilt Neon", sans-serif;
		width: 80vw;
		max-width: 320px;
		position: relative;
		border-radius: 10px;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3rem;
		color: #00eaff;
		background: #02000a;
		text-shadow:
			0 0 8px rgba(0, 234, 255, 0.9),
			0 0 16px rgba(255, 0, 255, 0.7);
		box-shadow:
			0 0 20px rgba(0, 234, 255, 0.9),
			0 0 45px rgba(255, 0, 255, 0.8);
		outline: none;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}

	#createBtn:hover,
	#submitCodeBtn:hover {
		text-shadow:
			0 0 12px rgba(0, 234, 255, 0.9),
			0 0 24px rgba(255, 0, 255, 0.7);
		box-shadow:
			0 0 60px rgba(0, 234, 255, 0.9),
			0 0 120px rgba(255, 0, 255, 0.8);
	}

	#createBtn:active,
	#submitCodeBtn:active {
		transform: scale(0.95);
	}

	#joinForm {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		margin-bottom: 5vh;
	}

	#joinForm label {
		font-family: "Tilt Neon", sans-serif;
		color: #00eaff;
		font-size: 1.25rem;
		text-shadow: 0 0 8px rgba(0, 234, 255, 0.6);
	}

	#gameCode {
		font-family: "Tilt Neon", sans-serif;
		font-size: 1.5rem;
		padding: 0.75rem 1rem;
		width: 80vw;
		max-width: 320px;
		box-sizing: border-box;
		border-radius: 10px;
		border: 2px solid rgba(0, 234, 255, 0.5);
		background: #02000a;
		color: #00eaff;
		outline: none;
		box-shadow: 0 0 12px rgba(0, 234, 255, 0.3);
	}

	#gameCode::placeholder {
		color: rgba(0, 234, 255, 0.5);
	}

	#gameCode:focus {
		border-color: #00eaff;
		box-shadow: 0 0 20px rgba(0, 234, 255, 0.6);
	}

	#submitCodeBtn {
		padding: 0 1.5rem;
	}

    #name-section {
        margin-bottom: 20px;
		display: none;
    }

    #player-name {
        padding: 10px;
        font-size: 16px;
        border: 2px solid rgba(0, 234, 255, 0.5);
        background: rgba(0, 0, 0, 0.5);
        color: white;
        border-radius: 4px;
        width: 200px;
        text-align: center;
    }

    #player-name:focus {
        outline: none;
        border-color: rgba(0, 234, 255, 0.9);
        box-shadow: 0 0 10px rgba(0, 234, 255, 0.5);
    }

    #player-name::placeholder {
        color: rgba(255, 255, 255, 0.5);
    }
</style>